@page "/criteria/create"
@page "/criteria/edit/{Id:guid}"
@using MediatR
@using TheContentor.Application.Features.Criteria.Models
@using TheContentor.Application.Features.Criteria.Queries
@using TheContentor.Application.Features.Criteria.Commands
@using TheContentor.Domain.Enums
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>@(_isEdit ? "Edit Criteria" : "Create Criteria")</PageTitle>

<h1>@(_isEdit ? "Edit Criteria" : "Create Criteria")</h1>

<div class="row">
    <div class="col-md-8">
        <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label for="name" class="form-label">Name</label>
                <InputText id="name" class="form-control" @bind-Value="_model.Name" />
            </div>

            <div class="mb-3">
                <label for="engine" class="form-label">Engine</label>
                <InputSelect id="engine" class="form-select" @bind-Value="_model.Engine">
                    @foreach (var engine in Enum.GetValues<CriteriaEngine>())
                    {
                        <option value="@engine">@engine</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label for="systemPrompt" class="form-label">System Prompt</label>
                <InputTextArea id="systemPrompt" class="form-control" @bind-Value="_model.SystemPrompt" rows="10" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox id="isActive" class="form-check-input" @bind-Value="_model.IsActive" />
                <label for="isActive" class="form-check-label">Is Active</label>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private CriteriaFormModel _model = new();
    private bool _isEdit => Id.HasValue;

    protected override async Task OnParametersSetAsync()
    {
        if (Id.HasValue)
        {
            var dto = await Mediator.Send(new GetCriteriaByIdQuery(Id.Value));
            if (dto != null)
            {
                _model = new CriteriaFormModel
                {
                    Name = dto.Name,
                    SystemPrompt = dto.SystemPrompt,
                    IsActive = dto.IsActive,
                    Engine = dto.Engine
                };
            }
            else
            {
                NavigationManager.NavigateTo("/criteria");
            }
        }
    }

    private async Task HandleSubmit()
    {
        if (_isEdit)
        {
            var command = new UpdateCriteriaCommand
            {
                Id = Id!.Value,
                Name = _model.Name,
                SystemPrompt = _model.SystemPrompt,
                IsActive = _model.IsActive,
                Engine = _model.Engine
            };
            await Mediator.Send(command);
        }
        else
        {
            var command = new CreateCriteriaCommand
            {
                Name = _model.Name,
                SystemPrompt = _model.SystemPrompt,
                IsActive = _model.IsActive,
                Engine = _model.Engine
            };
            await Mediator.Send(command);
        }

        NavigationManager.NavigateTo("/criteria");
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/criteria");
    }

    private class CriteriaFormModel
    {
        public string Name { get; set; } = string.Empty;
        public string SystemPrompt { get; set; } = string.Empty;
        public bool IsActive { get; set; } = true;
        public CriteriaEngine Engine { get; set; } = CriteriaEngine.Gemini;
    }
}
