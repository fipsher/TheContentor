@page "/criteria"
@using MediatR
@using TheContentor.Application.Features.Criteria.Models
@using TheContentor.Application.Features.Criteria.Queries
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Criteria Library</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Criteria Library</h1>
    <button class="btn btn-primary" @onclick="CreateNew">
        <i class="bi bi-plus-lg"></i> Create New
    </button>
</div>

@if (_criteria == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Name</th>
                <th>Engine</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _criteria)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Engine</td>
                    <td>
                        <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                            @(item.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(item.Id)">
                            <i class="bi bi-pencil"></i> Edit
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<CriteriaDto>? _criteria;

    protected override async Task OnInitializedAsync()
    {
        await LoadCriteria();
    }

    private async Task LoadCriteria()
    {
        _criteria = await Mediator.Send(new GetCriteriaListQuery());
    }

    private void CreateNew()
    {
        NavigationManager.NavigateTo("/criteria/create");
    }

    private void Edit(Guid id)
    {
        NavigationManager.NavigateTo($"/criteria/edit/{id}");
    }
}
