@using TheContentor.Application.Features.Assets.Models

@if (Asset == null)
{
    <div class="alert alert-warning mt-4">
        Unable to load the selected asset.
    </div>
}
else
{
    <div class="card mt-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>Viewing: @Asset.FileName</strong>
            <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="OnClose">
                <i class="bi bi-x-lg"></i> Close
            </button>
        </div>
        <div class="card-body">
            <video class="w-100" controls preload="metadata" playsinline>
                <source src="@StreamUrl" type="@ContentType" />
                Your browser does not support the video tag.
            </video>
        </div>
    </div>
}

@code {
    [Parameter]
    public AssetDto? Asset { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    private string StreamUrl => Asset == null ? string.Empty : $"/api/asset/{Asset.Id}/stream";

    private string ContentType => GetContentType(Asset?.FileName);

    private static string GetContentType(string? fileName)
    {
        if (string.IsNullOrWhiteSpace(fileName))
        {
            return "application/octet-stream";
        }

        var extension = Path.GetExtension(fileName);
        if (string.IsNullOrWhiteSpace(extension))
        {
            return "application/octet-stream";
        }

        return extension.ToLowerInvariant() switch
        {
            ".mp4" => "video/mp4",
            ".webm" => "video/webm",
            ".ogg" => "video/ogg",
            ".mov" => "video/quicktime",
            ".mkv" => "video/x-matroska",
            ".avi" => "video/x-msvideo",
            _ => "application/octet-stream"
        };
    }
}
