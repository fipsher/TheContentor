@page "/assets/create"
@page "/assets/edit/{Id:guid}"
@using MediatR
@using TheContentor.Application.Features.Assets.Models
@using TheContentor.Application.Features.Assets.Queries
@using TheContentor.Application.Features.Assets.Commands
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>@(_isEdit ? "Edit Asset" : "Add Asset")</PageTitle>

<h1>@(_isEdit ? "Edit Asset" : "Add Asset")</h1>

<div class="row">
    <div class="col-md-8">
        <EditForm Model="@_model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="mb-3">
                <label for="fileName" class="form-label">File Name</label>
                <InputText id="fileName" class="form-control" @bind-Value="_model.FileName" placeholder="e.g. park_drone_shot.mp4" />
            </div>

            @if (!_isEdit)
            {
                <div class="mb-3">
                    <label for="fileUpload" class="form-label">Upload Video File</label>
                    <InputFile id="fileUpload" class="form-control" OnChange="OnInputFileChange" accept="video/*" disabled="@_isUploading" />
                    @if (_isUploading)
                    {
                        <div class="mt-2">
                            <div class="spinner-border spinner-border-sm" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <span>Processing file...</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="mb-3">
                    <label for="localPath" class="form-label">Local Path / URL</label>
                    <InputText id="localPath" class="form-control" @bind-Value="_model.LocalPath" disabled />
                </div>
            }

            @if (_isEdit)
            {
                <div class="mb-3">
                    <label for="duration" class="form-label">Duration (hh:mm:ss)</label>
                    <div class="input-group">
                        <input type="time" id="duration" step="1" class="form-control" 
                               value="@_model.Duration.ToString(@"hh\:mm\:ss")" 
                               @onchange="@(e => { if(TimeSpan.TryParse(e.Value?.ToString(), out var ts)) _model.Duration = ts; })" />
                    </div>
                </div>
            }

            <div class="mb-3">
                <label for="tags" class="form-label">Tags (comma separated)</label>
                <InputText id="tags" class="form-control" @bind-Value="_model.Tags" placeholder="nature, relaxing, drone" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox id="isActive" class="form-check-input" @bind-Value="_model.IsActive" />
                <label for="isActive" class="form-check-label">Is Active</label>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancel">Cancel</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private AssetFormModel _model = new();
    private bool _isEdit => Id.HasValue;
    private bool _isUploading;
    private IBrowserFile? _browserFile;
    private string? _contentType;

    private void OnInputFileChange(InputFileChangeEventArgs e)
    {
        var file = e.File;
        _browserFile = file;
        if (string.IsNullOrEmpty(_model.FileName))
        {
            _model.FileName = file.Name;
        }
        _contentType = file.ContentType;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Id.HasValue)
        {
            var dto = await Mediator.Send(new GetAssetByIdQuery(Id.Value));
            if (dto != null)
            {
                _model = new AssetFormModel
                {
                    FileName = dto.FileName,
                    LocalPath = dto.LocalPath,
                    Tags = dto.Tags,
                    Duration = dto.Duration,
                    IsActive = dto.IsActive
                };
            }
            else
            {
                NavigationManager.NavigateTo("/assets");
            }
        }
    }

    private async Task HandleSubmit()
    {
        try
        {
            _isUploading = true;
            StateHasChanged();

            if (_isEdit)
            {
                var command = new UpdateAssetCommand
                {
                    Id = Id!.Value,
                    FileName = _model.FileName,
                    LocalPath = _model.LocalPath,
                    Tags = _model.Tags,
                    Duration = _model.Duration,
                    IsActive = _model.IsActive
                };
                await Mediator.Send(command);
            }
            else
            {
                Stream? stream = null;
                if (_browserFile != null)
                {
                    stream = _browserFile.OpenReadStream(maxAllowedSize: 500 * 1024 * 1024); // 500MB max
                }

                var command = new CreateAssetCommand
                {
                    FileName = _model.FileName,
                    Tags = _model.Tags,
                    IsActive = _model.IsActive,
                    FileStream = stream,
                    ContentType = _contentType
                };
                await Mediator.Send(command);
            }

            NavigationManager.NavigateTo("/assets");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[DEBUG_LOG] Error in HandleSubmit: {ex}");
            _isUploading = false;
            StateHasChanged();
            throw;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/assets");
    }

    private class AssetFormModel
    {
        public string FileName { get; set; } = string.Empty;
        public string LocalPath { get; set; } = string.Empty;
        public string Tags { get; set; } = string.Empty;
        public TimeSpan Duration { get; set; } = TimeSpan.Zero;
        public bool IsActive { get; set; } = true;
    }
}
