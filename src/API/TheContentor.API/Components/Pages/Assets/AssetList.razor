@page "/assets"
@using MediatR
@using TheContentor.Application.Features.Assets.Models
@using TheContentor.Application.Features.Assets.Queries
@using TheContentor.Application.Features.Assets.Commands
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Asset Library</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Asset Library</h1>
    <button class="btn btn-primary" @onclick="CreateNew">
        <i class="bi bi-plus-lg"></i> Add New Asset
    </button>
    <button class="btn btn-secondary" @onclick="ShowYouTubeUploadModal">
        <i class="bi bi-youtube"></i> Upload YouTube Asset
    </button>
</div>

@if (_assets == null)
{
    <p><em>Loading...</em></p>
}
else if (!_assets.Any())
{
    <div class="alert alert-info">
        No assets found. Click "Add New Asset" to get started.
    </div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>File Name</th>
                <th>Duration</th>
                <th>Tags</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _assets)
            {
                <tr>
                    <td>@item.FileName</td>
                    <td>@item.Duration?.ToString(@"mm\:ss")</td>
                    <td>
                        @foreach (var tag in item.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <span class="badge bg-info text-dark me-1">@tag.Trim()</span>
                        }
                    </td>
                    <td>
                        <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                            @(item.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <div class="btn-group">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewAsset(item)">
                                <i class="bi bi-play-circle"></i> View
                            </button>
                            <button class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")" 
                                    @onclick="() => ToggleStatus(item.Id)">
                                <i class="bi @(item.IsActive ? "bi-eye-slash" : "bi-eye")"></i> 
                                @(item.IsActive ? "Deactivate" : "Activate")
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_selectedAsset != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Viewing: @_selectedAsset.FileName</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body text-center">
                    <video controls autoplay class="img-fluid" style="max-height: 70vh;">
                        <source src="@_selectedAsset.SasUri.ToString()" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showYouTubeUploadModal)
{
    <YouTubeUploadModal ShowModal="_showYouTubeUploadModal" OnClose="HideYouTubeUploadModal" OnUpload="HandleYouTubeUpload"></YouTubeUploadModal>
}

@code {
    private List<AssetDto>? _assets;
    private AssetDto? _selectedAsset;
    private bool _showYouTubeUploadModal = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadAssets();
    }

    private async Task LoadAssets()
    {
        _assets = await Mediator.Send(new GetAssetListQuery());
    }

    private void CreateNew()
    {
        NavigationManager.NavigateTo("/assets/create");
    }

    private void ViewAsset(AssetDto asset)
    {
        _selectedAsset = asset;
    }

    private void CloseModal()
    {
        _selectedAsset = null;
    }

    private async Task ToggleStatus(Guid id)
    {
        var result = await Mediator.Send(new ToggleAssetStatusCommand(id));
        if (result)
        {
            await LoadAssets();
        }
    }

    private void ShowYouTubeUploadModal()
    {
        _showYouTubeUploadModal = true;
    }

    private void HideYouTubeUploadModal()
    {
        _showYouTubeUploadModal = false;
        // Optionally, reload assets after closing the modal if a new asset might have been added
        // await LoadAssets();
    }

    private async Task HandleYouTubeUpload(string youTubeUrl)
    {
        // TODO: Implement actual upload logic to backend
        Console.WriteLine($"YouTube URL received from modal: {youTubeUrl}");
        await LoadAssets(); // Reload assets after a successful upload
    }
}
