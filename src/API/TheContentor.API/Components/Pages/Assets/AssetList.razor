@page "/assets"
@using MediatR
@using TheContentor.Application.Features.Assets.Models
@using TheContentor.Application.Features.Assets.Queries
@using TheContentor.Application.Features.Assets.Commands
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Asset Library</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Asset Library</h1>
    <button class="btn btn-primary" @onclick="CreateNew">
        <i class="bi bi-plus-lg"></i> Add New Asset
    </button>
</div>

@if (_assets == null)
{
    <p><em>Loading...</em></p>
}
else if (!_assets.Any())
{
    <div class="alert alert-info">
        No assets found. Click "Add New Asset" to get started.
    </div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>File Name</th>
                <th>Duration</th>
                <th>Tags</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _assets)
            {
                <tr>
                    <td>@item.FileName</td>
                    <td>@item.Duration.ToString(@"mm\:ss")</td>
                    <td>
                        @foreach (var tag in item.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <span class="badge bg-info text-dark me-1">@tag.Trim()</span>
                        }
                    </td>
                    <td>
                        <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                            @(item.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <div class="btn-group">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => Edit(item.Id)">
                                <i class="bi bi-pencil"></i> Edit
                            </button>
                            <button class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")" 
                                    @onclick="() => ToggleStatus(item.Id)">
                                <i class="bi @(item.IsActive ? "bi-eye-slash" : "bi-eye")"></i> 
                                @(item.IsActive ? "Deactivate" : "Activate")
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<AssetDto>? _assets;

    protected override async Task OnInitializedAsync()
    {
        await LoadAssets();
    }

    private async Task LoadAssets()
    {
        _assets = await Mediator.Send(new GetAssetListQuery());
    }

    private void CreateNew()
    {
        NavigationManager.NavigateTo("/assets/create");
    }

    private void Edit(Guid id)
    {
        NavigationManager.NavigateTo($"/assets/edit/{id}");
    }

    private async Task ToggleStatus(Guid id)
    {
        var result = await Mediator.Send(new ToggleAssetStatusCommand(id));
        if (result)
        {
            await LoadAssets();
        }
    }
}
