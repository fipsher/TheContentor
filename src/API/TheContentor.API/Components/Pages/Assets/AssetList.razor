@page "/assets"
@using MediatR
@using TheContentor.Application.Features.Assets.Models
@using TheContentor.Application.Features.Assets.Queries
@using TheContentor.Application.Features.Assets.Commands
@using System.Text.RegularExpressions
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Asset Library</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Asset Library</h1>
    <button class="btn btn-primary" @onclick="CreateNew">
        <i class="bi bi-plus-lg"></i> Add New Asset
    </button>
</div>

<div class="d-flex align-items-center mb-2">
    <input type="text" class="form-control me-2" @bind-value="YouTubeUrl" placeholder="YouTube Video URL" />
    <button class="btn btn-secondary" @onclick="UploadFromYouTube" disabled="@(!_isYouTubeUrlValid)">
        <i class="bi bi-youtube"></i> Upload from YouTube
    </button>
</div>
@if (!string.IsNullOrWhiteSpace(_youTubeUrlError))
{
    <div class="alert alert-danger mt-2" role="alert">
        @_youTubeUrlError
    </div>
}

@if (_assets == null)
{
    <p><em>Loading...</em></p>
}
else if (!_assets.Any())
{
    <div class="alert alert-info">
        No assets found. Click "Add New Asset" to get started.
    </div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>File Name</th>
                <th>Duration</th>
                <th>Tags</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _assets)
            {
                <tr>
                    <td>@item.FileName</td>
                    <td>@item.Duration?.ToString(@"mm\:ss")</td>
                    <td>
                        @foreach (var tag in item.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries))
                        {
                            <span class="badge bg-info text-dark me-1">@tag.Trim()</span>
                        }
                    </td>
                    <td>
                        <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                            @(item.IsActive ? "Active" : "Inactive")
                        </span>
                    </td>
                    <td>
                        <div class="btn-group">
                            <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewAsset(item)">
                                <i class="bi bi-play-circle"></i> View
                            </button>
                            <button class="btn btn-sm @(item.IsActive ? "btn-outline-warning" : "btn-outline-success")" 
                                    @onclick="() => ToggleStatus(item.Id)">
                                <i class="bi @(item.IsActive ? "bi-eye-slash" : "bi-eye")"></i> 
                                @(item.IsActive ? "Deactivate" : "Activate")
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (_selectedAsset != null)
{
    <div class="modal fade show" style="display: block; background-color: rgba(0,0,0,0.5);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Viewing: @_selectedAsset.FileName</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body text-center">
                    <video controls autoplay class="img-fluid" style="max-height: 70vh;">
                        <source src="@_selectedAsset.SasUri.ToString()" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<AssetDto>? _assets;
    private AssetDto? _selectedAsset;

    private string _youTubeUrl = string.Empty;
    private bool _isYouTubeUrlValid = false;
    private string _youTubeUrlError = string.Empty;

    private string YouTubeUrl
    {
        get => _youTubeUrl;
        set
        {
            _youTubeUrl = value;
            ValidateYouTubeUrl();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadAssets();
        ValidateYouTubeUrl(); // Initial validation
    }

    private void ValidateYouTubeUrl()
    {
        _isYouTubeUrlValid = false;
        _youTubeUrlError = string.Empty;

        if (string.IsNullOrWhiteSpace(_youTubeUrl))
        {
            _youTubeUrlError = "URL cannot be empty.";
        }
        else if (!Regex.IsMatch(_youTubeUrl, @"^(https?://)?(www\.)?(youtube\.com|youtu\.be)/.+$"))
        {
            _youTubeUrlError = "Invalid YouTube URL format.";
        }
        else
        {
            _isYouTubeUrlValid = true;
        }
        // StateHasChanged(); // Only call if needed to force re-render, @bind-value usually handles this
    }

    private async Task UploadFromYouTube()
    {
        // TODO: Implement actual YouTube upload logic via API/Mediator
        if (_isYouTubeUrlValid && !string.IsNullOrWhiteSpace(_youTubeUrl))
        {
            Console.WriteLine($"Attempting to upload from YouTube URL: {_youTubeUrl}");
            // Clear the input after "upload" attempt
            YouTubeUrl = string.Empty; // Use the property to trigger validation
        }
    }
}
