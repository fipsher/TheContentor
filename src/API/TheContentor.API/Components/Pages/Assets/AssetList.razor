@page "/assets"
@using MediatR
@using System.Text.RegularExpressions
@using TheContentor.Application.Features.Assets.Models
@using TheContentor.Application.Features.Assets.Queries
@using TheContentor.Application.Features.Assets.Queries.GetYouTubeVideoMetadata
@using TheContentor.Application.Features.Assets.Commands
@using TheContentor.Domain.Enums
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Asset Library</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Asset Library</h1>
    <div class="d-flex align-items-center gap-2">
        <button class="status-pill @(_activeOnly ? "active pill-success" : "")"
                style="cursor:pointer;border:1px solid var(--border-color);border-radius:6px;padding:5px 12px;"
                @onclick="ToggleActiveOnly">
            <i class="bi @(_activeOnly ? "bi-eye" : "bi-eye-slash")"></i>
            @(_activeOnly ? "Active Only" : "Show All")
        </button>
        <button class="btn btn-primary btn-sm" @onclick="() => OpenAddModal(0)">
            <i class="bi bi-plus-lg"></i> Add Asset
        </button>
    </div>
</div>

@if (_assets == null)
{
    <div class="text-center py-5"><span class="spinner-border"></span></div>
}
else if (!_assets.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon"><i class="bi bi-collection-play"></i></div>
        <div class="empty-state-text">No assets found. Add one to get started.</div>
        <button class="btn btn-sm btn-primary mt-2" @onclick="() => OpenAddModal(0)">Add Asset</button>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover" style="table-layout:fixed;">
            <colgroup>
                <col style="width:120px;" />
                <col />
                <col style="width:90px;" />
                <col style="width:70px;" />
                <col style="width:80px;" />
                <col style="width:90px;" />
                <col style="width:80px;" />
                <col style="width:155px;" />
            </colgroup>
            <thead>
                <tr>
                    <th>Preview</th>
                    <th>Name</th>
                    <th>Source</th>
                    <th>Duration</th>
                    <th>Quality</th>
                    <th>Tag</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _assets)
                {
                    <tr>
                        <td>
                            <video src="@(item.SasUri + "#t=0.5")" class="asset-thumbnail" muted preload="metadata"></video>
                        </td>
                        <td style="overflow:hidden;">
                            <div style="font-size:0.8125rem;font-weight:500;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                @(item.Title ?? item.FileName)
                            </div>
                            @if (!string.IsNullOrEmpty(item.Title) && item.Title != item.FileName)
                            {
                                <div style="font-size:0.7rem;color:var(--text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    @item.FileName
                                </div>
                            }
                        </td>
                        <td>
                            @if (item.Type == AssetType.YouTube && !string.IsNullOrEmpty(item.OriginalUrl))
                            {
                                <a href="@item.OriginalUrl" target="_blank" class="btn btn-sm btn-outline-danger" title="Open YouTube">
                                    <i class="bi bi-youtube"></i>
                                </a>
                            }
                            else
                            {
                                <span class="tag-chip">Manual</span>
                            }
                        </td>
                        <td style="color:var(--text-secondary);font-size:0.8125rem;">
                            @item.Duration?.ToString(@"mm\:ss")
                        </td>
                        <td>
                            @if (item.Quality.HasValue)
                            {
                                <span class="quality-badge @GetQualityClass(item.Quality.Value)">@QualityLabel(item.Quality.Value)</span>
                            }
                            else
                            {
                                <span style="color:var(--text-muted);">—</span>
                            }
                        </td>
                        <td>
                            <select class="form-select form-select-sm"
                                    style="padding:2px 24px 2px 6px;font-size:0.75rem;height:auto;min-width:90px;"
                                    value="@(item.ContentTag?.ToString() ?? "")"
                                    @onchange="(e) => ChangeTag(item, e)">
                                <option value="">— None —</option>
                                @foreach (var tag in Enum.GetValues<AssetContentTag>())
                                {
                                    <option value="@tag">@tag</option>
                                }
                            </select>
                        </td>
                        <td>
                            <span class="status-badge @(item.IsActive ? "badge-active" : "badge-inactive")">
                                @(item.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                                <button class="icon-btn" title="Preview" @onclick="() => ViewAsset(item)">
                                    <i class="bi bi-play-circle"></i>
                                </button>
                                <button class="icon-btn" title="Edit" @onclick="() => EditAsset(item.Id)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="icon-btn" title="@ToggleTitle(item.IsActive)"
                                        style="@(item.IsActive ? "color:var(--accent-warning);" : "color:var(--accent-success);")"
                                        @onclick="() => ToggleStatus(item.Id)">
                                    <i class="bi @(item.IsActive ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div style="font-size:0.75rem;color:var(--text-muted);text-align:right;margin-top:-4px;">
        @_assets.Count asset@(_assets.Count == 1 ? "" : "s")
    </div>
}

<!-- Video preview modal -->
@if (_selectedAsset != null)
{
    <div class="modal fade show" style="display:block;" tabindex="-1" @onclick="CloseModal">
        <div class="modal-dialog modal-lg modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_selectedAsset.Title ?? _selectedAsset.FileName)</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body text-center">
                    <video controls autoplay class="img-fluid" style="max-height:70vh;">
                        <source src="@_selectedAsset.SasUri.ToString()" type="video/mp4">
                    </video>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Add Asset consolidated modal -->
@if (_showAddModal)
{
    <div class="modal fade show" style="display:block;" tabindex="-1" @onclick="CloseAddModal">
        <div class="modal-dialog modal-dialog-centered" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add Asset</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddModal" disabled="@_addLoading"></button>
                </div>
                <div class="modal-body">
                    <!-- Tabs -->
                    <div class="d-flex gap-1 mb-3" style="border-bottom:1px solid var(--border-color);padding-bottom:8px;">
                        <button class="btn btn-sm @(_addTab == 0 ? "btn-primary" : "btn-outline-secondary")" @onclick="() => SwitchAddTab(0)">
                            <i class="bi bi-upload"></i> Upload File
                        </button>
                        <button class="btn btn-sm @(_addTab == 1 ? "btn-primary" : "btn-outline-secondary")" @onclick="() => SwitchAddTab(1)">
                            <i class="bi bi-youtube"></i> YouTube
                        </button>
                    </div>

                    @if (_addTab == 0)
                    {
                        <!-- Upload File tab -->
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input type="text" class="form-control" @bind="_uploadName" placeholder="e.g. park_drone_shot.mp4" disabled="@_addLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Video File</label>
                            <InputFile class="form-control" OnChange="OnUploadFileChange" accept="video/*" disabled="@_addLoading" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Content Tag</label>
                            <select class="form-select" @bind="_uploadTag" disabled="@_addLoading">
                                <option value="">— None —</option>
                                @foreach (var tag in Enum.GetValues<AssetContentTag>())
                                {
                                    <option value="@tag">@tag</option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <!-- YouTube tab -->
                        @if (_ytPhase == YtPhase.Url)
                        {
                            <div class="mb-3">
                                <label class="form-label">YouTube Video URL</label>
                                <input type="text" class="form-control"
                                       @bind-value="_ytUrl" @bind-value:event="oninput"
                                       @onblur="ValidateYtUrl"
                                       placeholder="https://www.youtube.com/watch?v=..."
                                       disabled="@_addLoading" />
                                @if (!string.IsNullOrEmpty(_ytUrlError))
                                {
                                    <div class="text-danger mt-1" style="font-size:0.75rem;">@_ytUrlError</div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="mb-3">
                                <label class="form-label">Asset Name</label>
                                <input type="text" class="form-control" @bind="_ytName" placeholder="Asset name" disabled="@_addLoading" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Quality</label>
                                <select class="form-select" @bind="_ytQuality" disabled="@_addLoading">
                                    @foreach (var q in _ytQualities)
                                    {
                                        <option value="@q">@QualityLabel(q)</option>
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Content Tag</label>
                                <select class="form-select" @bind="_ytTag" disabled="@_addLoading">
                                    <option value="">— None —</option>
                                    @foreach (var tag in Enum.GetValues<AssetContentTag>())
                                    {
                                        <option value="@tag">@tag</option>
                                    }
                                </select>
                            </div>
                        }
                    }

                    @if (!string.IsNullOrEmpty(_addError))
                    {
                        <div class="alert alert-danger mt-2">@_addError</div>
                    }
                </div>
                <div class="modal-footer">
                    @if (_addTab == 0)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="CloseAddModal" disabled="@_addLoading">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="UploadFile"
                                disabled="@(_addLoading || string.IsNullOrWhiteSpace(_uploadName) || _uploadFile == null)">
                            @if (_addLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Upload
                        </button>
                    }
                    else if (_ytPhase == YtPhase.Url)
                    {
                        <button type="button" class="btn btn-secondary" @onclick="CloseAddModal" disabled="@_addLoading">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="FetchYtMetadata"
                                disabled="@(!_ytUrlValid || _addLoading)">
                            @if (_addLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Next
                        </button>
                    }
                    else
                    {
                        <button type="button" class="btn btn-link px-0 me-auto" @onclick="() => _ytPhase = YtPhase.Url" disabled="@_addLoading">← Back</button>
                        <button type="button" class="btn btn-secondary" @onclick="CloseAddModal" disabled="@_addLoading">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="UploadYouTube"
                                disabled="@(_addLoading || string.IsNullOrWhiteSpace(_ytName))">
                            @if (_addLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Upload
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<AssetDto>? _assets;
    private AssetDto? _selectedAsset;
    private bool _activeOnly;

    // Add modal
    private bool _showAddModal;
    private int _addTab;
    private bool _addLoading;
    private string? _addError;

    // Upload file tab
    private string _uploadName = "";
    private IBrowserFile? _uploadFile;
    private string? _uploadContentType;
    private AssetContentTag? _uploadTag;

    // YouTube tab
    private enum YtPhase { Url, Details }
    private YtPhase _ytPhase = YtPhase.Url;
    private string _ytUrl = "";
    private bool _ytUrlValid;
    private string _ytUrlError = "";
    private string _ytName = "";
    private IReadOnlyList<YouTubeVideoQuality> _ytQualities = [];
    private YouTubeVideoQuality _ytQuality;
    private AssetContentTag? _ytTag;

    protected override async Task OnInitializedAsync() => await LoadAssets();

    private async Task LoadAssets()
    {
        _assets = await Mediator.Send(new GetAssetListQuery(_activeOnly));
    }

    private async Task ToggleActiveOnly()
    {
        _activeOnly = !_activeOnly;
        await LoadAssets();
    }

    private void EditAsset(Guid id) => NavigationManager.NavigateTo("/assets/edit/" + id);

    private void ViewAsset(AssetDto asset) => _selectedAsset = asset;
    private void CloseModal() => _selectedAsset = null;

    private async Task ToggleStatus(Guid id)
    {
        if (await Mediator.Send(new ToggleAssetStatusCommand(id)))
            await LoadAssets();
    }

    private void OpenAddModal(int tab)
    {
        _addTab = tab;
        _showAddModal = true;
        _addError = null;
    }

    private void CloseAddModal()
    {
        if (_addLoading) return;
        _showAddModal = false;
        ResetAddModal();
    }

    private void ResetAddModal()
    {
        _uploadName = "";
        _uploadFile = null;
        _uploadContentType = null;
        _uploadTag = null;
        _ytPhase = YtPhase.Url;
        _ytUrl = "";
        _ytUrlValid = false;
        _ytUrlError = "";
        _ytName = "";
        _ytQualities = [];
        _ytQuality = default;
        _ytTag = null;
        _addError = null;
    }

    private void SwitchAddTab(int tab)
    {
        _addTab = tab;
        _addError = null;
    }

    private void OnUploadFileChange(InputFileChangeEventArgs e)
    {
        _uploadFile = e.File;
        if (string.IsNullOrEmpty(_uploadName))
            _uploadName = e.File.Name;
        _uploadContentType = e.File.ContentType;
    }

    private async Task UploadFile()
    {
        if (string.IsNullOrWhiteSpace(_uploadName) || _uploadFile == null) return;
        _addLoading = true;
        _addError = null;
        try
        {
            Stream? stream = _uploadFile?.OpenReadStream(maxAllowedSize: 500 * 1024 * 1024);
            await Mediator.Send(new CreateAssetCommand
            {
                Name = _uploadName,
                ContentTag = _uploadTag,
                FileStream = stream,
                ContentType = _uploadContentType
            });
            _showAddModal = false;
            ResetAddModal();
            await LoadAssets();
        }
        catch (Exception ex)
        {
            _addError = ex.Message;
        }
        finally
        {
            _addLoading = false;
        }
    }

    private void ValidateYtUrl()
    {
        if (string.IsNullOrWhiteSpace(_ytUrl))
        { _ytUrlValid = false; _ytUrlError = "URL cannot be empty."; return; }
        if (!Regex.IsMatch(_ytUrl, @"^(https?://)?(www\.)?(youtube\.com|youtu\.be)/.+$"))
        { _ytUrlValid = false; _ytUrlError = "Invalid YouTube URL."; return; }
        _ytUrlValid = true;
        _ytUrlError = "";
    }

    private async Task FetchYtMetadata()
    {
        ValidateYtUrl();
        if (!_ytUrlValid) return;
        _addLoading = true;
        _addError = null;
        try
        {
            var metadata = await Mediator.Send(new GetYouTubeVideoMetadataQuery(_ytUrl));
            _ytName = metadata.Title;
            _ytQualities = metadata.AvailableQualities;
            _ytQuality = _ytQualities.Count > 0 ? _ytQualities[^1] : YouTubeVideoQuality.P1080;
            _ytPhase = YtPhase.Details;
        }
        catch (Exception ex) { _addError = ex.Message; }
        finally { _addLoading = false; }
    }

    private async Task UploadYouTube()
    {
        if (string.IsNullOrWhiteSpace(_ytName)) return;
        _addLoading = true;
        _addError = null;
        try
        {
            await Mediator.Send(new UploadYouTubeAssetCommand(_ytUrl, _ytName, _ytQuality, _ytTag));
            _showAddModal = false;
            ResetAddModal();
            await LoadAssets();
        }
        catch (Exception ex) { _addError = ex.Message; }
        finally { _addLoading = false; }
    }

    private async Task ChangeTag(AssetDto item, ChangeEventArgs e)
    {
        var val = e.Value?.ToString();
        AssetContentTag? newTag = string.IsNullOrEmpty(val) ? null : Enum.Parse<AssetContentTag>(val);
        if (newTag == item.ContentTag) return;
        await Mediator.Send(new RenameAssetCommand(item.Id, item.FileName, newTag));
        item.ContentTag = newTag;
    }

    private static string ToggleTitle(bool isActive) => isActive ? "Deactivate" : "Activate";

    private static string QualityLabel(YouTubeVideoQuality q) => q switch
    {
        YouTubeVideoQuality.P144  => "144p",
        YouTubeVideoQuality.P240  => "240p",
        YouTubeVideoQuality.P360  => "360p",
        YouTubeVideoQuality.P480  => "480p",
        YouTubeVideoQuality.P720  => "720p HD",
        YouTubeVideoQuality.P1080 => "1080p FHD",
        YouTubeVideoQuality.P1440 => "1440p 2K",
        YouTubeVideoQuality.P2160 => "2160p 4K",
        _ => q.ToString()
    };

    private static string GetQualityClass(YouTubeVideoQuality q) => q switch
    {
        YouTubeVideoQuality.P144  => "quality-144",
        YouTubeVideoQuality.P240  => "quality-240",
        YouTubeVideoQuality.P360  => "quality-360",
        YouTubeVideoQuality.P480  => "quality-480",
        YouTubeVideoQuality.P720  => "quality-720",
        YouTubeVideoQuality.P1080 => "quality-1080",
        YouTubeVideoQuality.P1440 => "quality-1440",
        YouTubeVideoQuality.P2160 => "quality-2160",
        _ => ""
    };
}