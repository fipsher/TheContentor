@using TheContentor.Application.Features.Schedule.Models
@using TheContentor.Domain.Enums

<div class="week-post-card" @onclick="() => OnNavigate.InvokeAsync(Post.SourcePostId)">
    <div class="week-post-card__top">
        <span class="badge @GetStatusBadgeClass(Post)" style="font-size:0.6rem">@GetStatusLabel(Post)</span>
        <span class="badge bg-secondary" style="font-size:0.6rem">@Post.Community</span>
        <button class="btn btn-link p-0 text-danger remove-btn ms-auto"
                title="Remove"
                @onclick:stopPropagation
                @onclick="() => OnRemove.InvokeAsync(Post.ScheduledPostId)">&#xD7;</button>
    </div>
    <div class="week-post-card__title">@Post.Title</div>
    <div class="week-post-card__meta">
        <span>&#9650; @Post.Score</span>
        <span>@Post.WordCount w</span>
        @if (!ShowVideoPreview || Post.VideoSasUrl == null)
        {
            <span class="week-post-card__video-dot @GetVideoDotClass(Post.VideoStatus)" title="@GetVideoStatusLabel(Post.VideoStatus)"></span>
        }
    </div>
    <div class="week-post-card__actions" @onclick:stopPropagation>
        @if (IsInProgress)
        {
            <div class="week-post-progress">
                <div class="progress" style="height:4px;flex:1;">
                    <div class="progress-bar progress-bar-striped progress-bar-animated" style="width:100%"></div>
                </div>
                <small style="font-size:0.55rem;color:var(--text-muted);white-space:nowrap;">@InProgressLabel</small>
            </div>
        }
        else if (!Post.IsProcessed && Post.IsPosted != true)
        {
            <button class="btn btn-outline-warning week-action-btn" title="Process with AI"
                    @onclick="() => OnProcessAI.InvokeAsync(Post.SourcePostId)">
                <i class="bi bi-cpu"></i>
            </button>
        }
        else if (Post.VideoStatus != VideoStatus.Generated && Post.IsPosted != true)
        {
            <button class="btn btn-outline-success week-action-btn" title="Generate Video"
                    @onclick="() => OnGenerate.InvokeAsync(Post)">
                <i class="bi bi-film"></i>
            </button>
        }
    </div>
    @if (ShowVideoPreview && Post.VideoSasUrl != null)
    {
        <div class="week-post-card__thumb" @onclick:stopPropagation @onclick="OpenVideo">
            <video src="@(Post.VideoSasUrl + "#t=0.5")" muted preload="metadata" class="week-post-thumb-video"></video>
            <div class="week-post-thumb-play">&#9654;</div>
        </div>
    }
</div>

@if (_previewUrl != null)
{
    <div class="video-preview-overlay" @onclick="() => _previewUrl = null">
        <div class="iphone-frame" @onclick:stopPropagation>
            <video src="@_previewUrl" controls autoplay class="iphone-video"></video>
        </div>
    </div>
}

@code {
    /// <summary>The scheduled post data to display.</summary>
    [Parameter]
    public ScheduledDayDto Post { get; set; } = null!;

    /// <summary>Callback fired with the source post identifier when the card is clicked.</summary>
    [Parameter]
    public EventCallback<Guid> OnNavigate { get; set; }

    /// <summary>Callback fired with the scheduled post identifier when the remove button is clicked.</summary>
    [Parameter]
    public EventCallback<Guid> OnRemove { get; set; }

    /// <summary>When true and a video SAS URL is available, displays an inline video thumbnail.</summary>
    [Parameter]
    public bool ShowVideoPreview { get; set; } = false;

    /// <summary>Callback fired when the "Process with AI" button is clicked.</summary>
    [Parameter]
    public EventCallback<Guid> OnProcessAI { get; set; }

    /// <summary>Callback fired when the "Generate Video" button is clicked.</summary>
    [Parameter]
    public EventCallback<ScheduledDayDto> OnGenerate { get; set; }

    /// <summary>Current AI processing stage text. Null when not actively receiving updates.</summary>
    [Parameter]
    public string? AiProgressStage { get; set; }

    private string? _previewUrl;

    private bool IsInProgress => Post.SourcePostStatus == SourcePostStatus.Processing
                              || Post.TtsStatus == TtsStatus.InProgress
                              || Post.VideoStatus == VideoStatus.InProgress;

    private string InProgressLabel => Post.SourcePostStatus == SourcePostStatus.Processing
        ? (AiProgressStage ?? "AI…") : Post.TtsStatus == TtsStatus.InProgress ? "TTS…" : "Video…";

    private void OpenVideo() => _previewUrl = Post.VideoSasUrl;

    private static string GetStatusLabel(ScheduledDayDto post)
    {
        if (post.IsPosted == true) return "Posted";
        if (post.SourcePostStatus == SourcePostStatus.Processing) return "AI Processing";
        if (post.TtsStatus == TtsStatus.InProgress) return "TTS In Progress";
        if (post.VideoStatus == VideoStatus.InProgress) return "Video In Progress";
        if (!post.IsProcessed) return "Not Processed";
        if (post.VideoStatus == VideoStatus.Generated) return "Video Ready";
        if (post.VideoStatus == VideoStatus.Failed) return "Video Failed";
        return "AI Processed";
    }

    private static string GetStatusBadgeClass(ScheduledDayDto post)
    {
        if (post.IsPosted == true) return "bg-info";
        if (post.SourcePostStatus == SourcePostStatus.Processing) return "bg-warning text-dark";
        if (post.TtsStatus == TtsStatus.InProgress || post.VideoStatus == VideoStatus.InProgress) return "bg-warning text-dark";
        if (!post.IsProcessed) return "bg-secondary";
        if (post.VideoStatus == VideoStatus.Generated) return "bg-success";
        if (post.VideoStatus == VideoStatus.Failed) return "bg-danger";
        return "bg-primary";
    }

    private static string GetVideoDotClass(VideoStatus? status) => status switch
    {
        VideoStatus.Generated   => "video-dot--generated",
        VideoStatus.InProgress  => "video-dot--in-progress",
        VideoStatus.Failed      => "video-dot--failed",
        _                       => "video-dot--none"
    };

    private static string GetVideoStatusLabel(VideoStatus? status) => status switch
    {
        VideoStatus.Generated   => "Video ready",
        VideoStatus.InProgress  => "Video in progress",
        VideoStatus.Failed      => "Video failed",
        _                       => "No video"
    };
}
