@code {
    private enum ViewMode { Month, Week }
    private ViewMode _viewMode = ViewMode.Week;
    private DateOnly _weekStart = GetCurrentWeekStart();

    private int _year = DateTime.Today.Year;
    private int _month = DateTime.Today.Month;

    private List<ScheduledDayDto>? _schedule;

    // Auto-schedule
    private DateTime _autoStart = DateTime.Today;
    private DateTime _autoEnd = DateTime.Today.AddDays(6);
    private string _autoCommunity = "";
    private bool _autoRunning;

    // Add-post picker
    private DateOnly? _addPostDate;
    private List<SourcePostListItemDto>? _availablePosts;
    private string _postPickerSearch = "";

    private string? _errorMessage;
    private string? _successMessage;

    // AI Process modal
    private bool _showProcessModal;
    private bool _aiProcessing;
    private Guid? _processSourcePostId;
    private LlmProvider _llmProvider = LlmProvider.Gemini;
    private string _localModelName = "";

    // Generate dialog
    private bool _showGenerateDialog;
    private Guid? _generatePostId;
    private NarratorGender _generateGender = NarratorGender.Male;

    // Generate Week
    private bool _generateWeekRunning;
    private GenerateWeekProgressPayload? _generateWeekProgress;

    // SignalR
    private HubConnection? _hubConnection;
    private HashSet<Guid> _joinedGroups = new();
    private HashSet<Guid> _joinedAiGroups = new();
    private Dictionary<Guid, string> _aiProgressStages = new();

    private record CalendarCell(int Day, DateOnly Date, bool IsToday, bool IsCurrentWeek, List<ScheduledDayDto> Posts);

    private int DaysInMonth => DateTime.DaysInMonth(_year, _month);

    private int LeadingBlanks
    {
        get
        {
            var firstDay = new DateTime(_year, _month, 1).DayOfWeek;
            return firstDay == DayOfWeek.Sunday ? 6 : (int)firstDay - 1;
        }
    }

    private List<CalendarCell> CalendarCells
    {
        get
        {
            if (_schedule == null) return [];
            var today = DateOnly.FromDateTime(DateTime.Today);
            var weekStart = today.AddDays(today.DayOfWeek == DayOfWeek.Sunday ? -6 : -(int)today.DayOfWeek + 1);
            var weekEnd = weekStart.AddDays(6);
            return Enumerable.Range(1, DaysInMonth)
                .Select(d =>
                {
                    var date = new DateOnly(_year, _month, d);
                    return new CalendarCell(
                        Day: d,
                        Date: date,
                        IsToday: date == today,
                        IsCurrentWeek: date >= weekStart && date <= weekEnd,
                        Posts: _schedule.Where(x => x.ScheduledDate == date).ToList()
                    );
                })
                .ToList();
        }
    }

    private IEnumerable<SourcePostListItemDto> FilteredAvailablePosts =>
        _availablePosts == null
            ? []
            : _availablePosts.Where(p =>
                string.IsNullOrWhiteSpace(_postPickerSearch) ||
                p.Title.Contains(_postPickerSearch, StringComparison.OrdinalIgnoreCase) ||
                p.Community.Contains(_postPickerSearch, StringComparison.OrdinalIgnoreCase));

    private static DateOnly GetCurrentWeekStart()
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        return today.AddDays(today.DayOfWeek == DayOfWeek.Sunday ? -6 : -(int)today.DayOfWeek + 1);
    }

    protected override async Task OnInitializedAsync()
    {
        await RefreshSchedule();
    }

    private async Task JoinInProgressGroups()
    {
        if (_hubConnection?.State != HubConnectionState.Connected || _schedule == null) return;

        var inProgressIds = _schedule
            .Where(s => s.ProcessedPostId.HasValue
                && (s.TtsStatus == TtsStatus.InProgress || s.VideoStatus == VideoStatus.InProgress))
            .Select(s => s.ProcessedPostId!.Value)
            .ToHashSet();

        // Leave groups no longer in progress
        foreach (var id in _joinedGroups.Except(inProgressIds).ToList())
        {
            await _hubConnection.InvokeAsync("LeavePostGroup", id);
            _joinedGroups.Remove(id);
        }

        // Join new in-progress groups
        foreach (var id in inProgressIds.Except(_joinedGroups))
        {
            await _hubConnection.InvokeAsync("JoinPostGroup", id);
            _joinedGroups.Add(id);
        }
    }

    private async Task JoinAiProcessingGroups()
    {
        if (_hubConnection?.State != HubConnectionState.Connected || _schedule == null) return;

        var processingIds = _schedule
            .Where(s => s.SourcePostStatus == SourcePostStatus.Processing)
            .Select(s => s.SourcePostId)
            .ToHashSet();

        foreach (var id in _joinedAiGroups.Except(processingIds).ToList())
        {
            await _hubConnection.InvokeAsync("LeaveSourcePostGroup", id);
            _joinedAiGroups.Remove(id);
        }

        foreach (var id in processingIds.Except(_joinedAiGroups))
        {
            await _hubConnection.InvokeAsync("JoinSourcePostGroup", id);
            _joinedAiGroups.Add(id);
        }
    }

    /// <inheritdoc/>
    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
            await _hubConnection.DisposeAsync();
    }

    /// <inheritdoc />
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", "schedule-view-mode");
            if (saved == "Week") { _viewMode = ViewMode.Week; await RefreshSchedule(); }

            _hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/video-generation"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<GenerationProgressModel>("ProgressUpdate", async (progress) =>
            {
                if (progress.IsComplete)
                {
                    await RefreshSchedule();
                    await JoinInProgressGroups();
                }
                await InvokeAsync(StateHasChanged);
            });

            _hubConnection.On<GenerateWeekProgressPayload>("GenerateWeekUpdate", async (progress) =>
            {
                _generateWeekProgress = progress;
                if (progress.IsComplete)
                {
                    _generateWeekRunning = false;
                    await RefreshSchedule();
                    await JoinInProgressGroups();
                    await JoinAiProcessingGroups();
                }
                else
                {
                    // Refresh to pick up status changes as posts get processed
                    await RefreshSchedule();
                }
                await InvokeAsync(StateHasChanged);
            });

            _hubConnection.On<AiProcessingProgressModel>("AiProcessingUpdate", async (progress) =>
            {
                if (progress.IsComplete)
                {
                    _aiProgressStages.Remove(progress.SourcePostId);
                    await RefreshSchedule();
                    await JoinAiProcessingGroups();
                }
                else
                {
                    _aiProgressStages[progress.SourcePostId] = progress.Stage;
                }
                await InvokeAsync(StateHasChanged);
            });

            await _hubConnection.StartAsync();
            await JoinInProgressGroups();
            await JoinAiProcessingGroups();
        }
    }

    private async Task SetView(ViewMode mode)
    {
        _viewMode = mode;
        await JS.InvokeVoidAsync("localStorage.setItem", "schedule-view-mode", mode.ToString());
        await RefreshSchedule();
    }

    private async Task RefreshSchedule()
    {
        _schedule = null;
        if (_viewMode == ViewMode.Week)
            _schedule = await Mediator.Send(new GetScheduleWeekQuery(_weekStart));
        else
            _schedule = await Mediator.Send(new GetScheduleQuery(_year, _month));
    }

    private async Task PreviousMonth()
    {
        if (_month == 1) { _month = 12; _year--; }
        else _month--;
        await RefreshSchedule();
    }

    private async Task NextMonth()
    {
        if (_month == 12) { _month = 1; _year++; }
        else _month++;
        await RefreshSchedule();
    }

    private async Task PreviousWeek() { _weekStart = _weekStart.AddDays(-7); await RefreshSchedule(); }
    private async Task NextWeek()     { _weekStart = _weekStart.AddDays(7);  await RefreshSchedule(); }

    private async Task HandlePrevious()
    {
        if (_viewMode == ViewMode.Week) await PreviousWeek();
        else await PreviousMonth();
    }

    private async Task HandleNext()
    {
        if (_viewMode == ViewMode.Week) await NextWeek();
        else await NextMonth();
    }

    private async Task RemoveEntry(Guid scheduledPostId)
    {
        try
        {
            await Mediator.Send(new RemoveScheduledPostCommand(scheduledPostId));
            await RefreshSchedule();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task RunAutoSchedule()
    {
        _errorMessage = null;
        _successMessage = null;
        _autoRunning = true;

        try
        {
            var start = DateOnly.FromDateTime(_autoStart);
            var end = DateOnly.FromDateTime(_autoEnd);
            var community = string.IsNullOrWhiteSpace(_autoCommunity) ? null : _autoCommunity.Trim();
            var count = await Mediator.Send(new AutoScheduleCommand(start, end, community));
            _successMessage = $"Scheduled {count} post(s) successfully.";
            await RefreshSchedule();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _autoRunning = false;
        }
    }

    private async Task AutoAssignDay(DateOnly date)
    {
        _errorMessage = null;
        try
        {
            var count = await Mediator.Send(new AutoScheduleCommand(date, date, null));
            if (count == 0)
                _errorMessage = "No eligible posts to assign for this day.";
            else
                await RefreshSchedule();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private async Task OpenAddPost(DateOnly date)
    {
        _addPostDate = date;
        _postPickerSearch = "";
        _availablePosts = null;

        var all = await Mediator.Send(new GetSourcePostListQuery());
        _availablePosts = all
            .Where(p => p.IsPosted != true)
            .OrderByDescending(p => p.Score)
            .ToList();
    }

    private void CloseAddPost()
    {
        _addPostDate = null;
        _availablePosts = null;
    }

    private async Task AddPost(DateOnly date, Guid sourcePostId)
    {
        _errorMessage = null;
        try
        {
            await Mediator.Send(new CreateScheduledPostCommand(date, sourcePostId));
            CloseAddPost();
            await RefreshSchedule();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
    }

    private void GoToPost(Guid sourcePostId) =>
        NavigationManager.NavigateTo($"/source-posts/{sourcePostId}");

    private static string GetStatusLabel(ScheduledDayDto post)
    {
        if (post.IsPosted == true) return "Posted";
        if (post.SourcePostStatus == SourcePostStatus.Processing) return "AI Processing";
        if (post.TtsStatus == TtsStatus.InProgress) return "TTS In Progress";
        if (post.VideoStatus == VideoStatus.InProgress) return "Video In Progress";
        if (!post.IsProcessed) return "Not Processed";
        if (post.VideoStatus == VideoStatus.Generated) return "Video Ready";
        if (post.VideoStatus == VideoStatus.Failed) return "Video Failed";
        return "AI Processed";
    }

    private static string GetStatusBadgeClass(ScheduledDayDto post)
    {
        if (post.IsPosted == true) return "bg-info";
        if (post.SourcePostStatus == SourcePostStatus.Processing) return "bg-warning text-dark";
        if (post.TtsStatus == TtsStatus.InProgress || post.VideoStatus == VideoStatus.InProgress) return "bg-warning text-dark";
        if (!post.IsProcessed) return "bg-secondary";
        if (post.VideoStatus == VideoStatus.Generated) return "bg-success";
        if (post.VideoStatus == VideoStatus.Failed) return "bg-danger";
        return "bg-primary";
    }

    private void OpenProcessAI(Guid sourcePostId)
    {
        _processSourcePostId = sourcePostId;
        _showProcessModal = true;
    }

    private async Task ConfirmProcessAI()
    {
        if (_processSourcePostId == null) return;
        _aiProcessing = true;
        _errorMessage = null;
        try
        {
            var localModelName = _llmProvider == LlmProvider.Local && !string.IsNullOrWhiteSpace(_localModelName)
            ? _localModelName
            : null;
        await Mediator.Send(new QueueAiProcessingCommand(_processSourcePostId.Value, LlmProvider: _llmProvider, LocalModelName: localModelName));
            _showProcessModal = false;
            _successMessage = "AI processing queued.";
            await RefreshSchedule();
            await JoinAiProcessingGroups();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _showProcessModal = false;
        }
        finally
        {
            _aiProcessing = false;
        }
    }

    private void OpenGenerateDialog(ScheduledDayDto post)
    {
        if (post.ProcessedPostId == null) return;
        _generatePostId = post.ProcessedPostId;
        _generateGender = post.NarratorGender ?? NarratorGender.Male;
        _showGenerateDialog = true;
    }

    private async Task CloseGenerateDialog()
    {
        _showGenerateDialog = false;
        await Task.CompletedTask;
    }

    private async Task OnGenerated()
    {
        _successMessage = "Video generation started.";
        await RefreshSchedule();
        await JoinInProgressGroups();
    }

    private async Task GenerateWeek()
    {
        _errorMessage = null;
        _successMessage = null;
        _generateWeekRunning = true;
        _generateWeekProgress = null;

        try
        {
            // Join SignalR group for week progress
            var weekKey = _weekStart.ToString("yyyy-MM-dd");
            if (_hubConnection?.State == HubConnectionState.Connected)
            {
                await _hubConnection.InvokeAsync("JoinGenerateWeekGroup", weekKey);
            }

            var count = await Mediator.Send(new GenerateWeekCommand(_weekStart));
            if (count == 0)
            {
                _errorMessage = "No eligible posts to process for this week.";
                _generateWeekRunning = false;
            }
            else
            {
                _generateWeekProgress = new GenerateWeekProgressPayload
                {
                    WeekStart = weekKey,
                    TotalPosts = count,
                    CompletedPosts = 0,
                    Stage = "Queued for processing..."
                };
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _generateWeekRunning = false;
        }
    }

    private void DismissGenerateWeekProgress()
    {
        _generateWeekProgress = null;
    }

    private static string TruncateTitle(string title) =>
        title.Length > 38 ? title[..38] + "\u2026" : title;
}
