@page "/"
@page "/schedule"
@using MediatR
@using Microsoft.JSInterop
@using TheContentor.Application.Features.Schedule.Commands
@using TheContentor.Application.Features.Schedule.Models
@using TheContentor.Application.Features.Schedule.Queries
@using TheContentor.Application.Features.SourcePosts.Models
@using TheContentor.Application.Features.SourcePosts.Queries
@using TheContentor.Application.Features.SourcePosts.Commands
@using TheContentor.Application.Features.ProcessedPosts.Commands
@using TheContentor.Application.Features.ProcessedPosts.Models
@using TheContentor.Application.Features.Assets.Queries
@using TheContentor.Application.Features.Assets.Models
@using TheContentor.API.Controllers
@using TheContentor.Domain.Enums
@using Microsoft.AspNetCore.SignalR.Client
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Schedule</PageTitle>

<GenerateAllDialog IsVisible="_showGenerateDialog"
                   ProcessedPostId="_generatePostId"
                   Gender="_generateGender"
                   OnClose="CloseGenerateDialog"
                   OnGenerated="OnGenerated" />

@if (_showProcessModal)
{
    <div class="modal fade show" style="display:block;" tabindex="-1" @onclick="() => _showProcessModal = false">
        <div class="modal-dialog modal-dialog-centered" style="max-width:420px;" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-cpu me-2" style="color:var(--accent-warning);"></i> AI Processing</h5>
                    <button type="button" class="btn-close" @onclick="() => _showProcessModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">LLM Provider</label>
                        <select class="form-select" @bind="_llmProvider">
                            <option value="@LlmProvider.Gemini">Google Gemini</option>
                            <option value="@LlmProvider.OpenAI">OpenAI ChatGPT</option>
                            <option value="@LlmProvider.Local">Local (Ollama)</option>
                        </select>
                    </div>

                    @if (_llmProvider == LlmProvider.Local)
                    {
                        <div class="mb-3">
                            <label class="form-label">Model Name</label>
                            <input type="text" class="form-control" placeholder="qwen2.5:7b"
                                   @bind="_localModelName" />
                            <div class="form-text">
                                Model must be pulled via <code>ollama pull &lt;model&gt;</code>.
                                Examples: <code>qwen2.5:7b</code>, <code>gemma3:9b</code>, <code>llama3.3:70b</code>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _showProcessModal = false" disabled="@_aiProcessing">Cancel</button>
                    <button type="button" class="btn btn-warning" @onclick="ConfirmProcessAI" disabled="@_aiProcessing">
                        @if (_aiProcessing)
                        {
                            <span class="spinner-border spinner-border-sm me-1"></span>
                        }
                        <i class="bi bi-cpu me-1"></i> Process
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Schedule</h1>
</div>

@if (_errorMessage != null)
{
    <div class="alert alert-danger alert-dismissible">
        @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@if (_successMessage != null)
{
    <div class="alert alert-success alert-dismissible">
        @_successMessage
        <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
    </div>
}

<!-- Auto-Schedule Panel -->
<div class="card mb-4">
    <div class="card-header fw-semibold">Auto Schedule</div>
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">From</label>
                <input type="date" class="form-control" @bind="_autoStart" />
            </div>
            <div class="col-md-3">
                <label class="form-label">To</label>
                <input type="date" class="form-control" @bind="_autoEnd" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Community (optional)</label>
                <input type="text" class="form-control" @bind="_autoCommunity" placeholder="e.g. AskReddit" />
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary w-100" @onclick="RunAutoSchedule" disabled="@_autoRunning">
                    @if (_autoRunning)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Auto Schedule
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Calendar Navigation -->
<div class="d-flex justify-content-between align-items-center mb-3 gap-2 flex-wrap">
    <button class="btn btn-outline-secondary" @onclick="HandlePrevious">&lsaquo; Previous</button>

    <div class="d-flex align-items-center gap-3">
        <h4 class="mb-0">
            @if (_viewMode == ViewMode.Month)
            {
                @(new DateTime(_year, _month, 1).ToString("MMMM yyyy"))
            }
            else
            {
                @($"{_weekStart:MMM d} – {_weekStart.AddDays(6):MMM d, yyyy}")
            }
        </h4>
        <div class="status-pill-group">
            <button class="status-pill @(_viewMode == ViewMode.Month ? "active" : "")"
                    @onclick="() => SetView(ViewMode.Month)">Month</button>
            <button class="status-pill @(_viewMode == ViewMode.Week ? "active" : "")"
                    @onclick="() => SetView(ViewMode.Week)">Week</button>
        </div>
    </div>

    <div class="d-flex align-items-center gap-2">
        @if (_viewMode == ViewMode.Week)
        {
            <button class="btn btn-success btn-sm" @onclick="GenerateWeek" disabled="@(_generateWeekRunning || _generateWeekProgress != null)">
                @if (_generateWeekRunning)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Generate Week
            </button>
        }
        <button class="btn btn-outline-secondary" @onclick="HandleNext">Next &rsaquo;</button>
    </div>
</div>

@if (_generateWeekProgress != null)
{
    <div class="alert @(_generateWeekProgress.HasError ? "alert-danger" : _generateWeekProgress.IsComplete ? "alert-success" : "alert-info") d-flex align-items-center gap-3 mb-3">
        @if (!_generateWeekProgress.IsComplete)
        {
            <div class="spinner-border spinner-border-sm"></div>
        }
        <div class="flex-grow-1">
            <div class="fw-semibold mb-1">
                Generate Week: @_generateWeekProgress.CompletedPosts / @_generateWeekProgress.TotalPosts posts
            </div>
            <div class="progress" style="height:6px;">
                <div class="progress-bar @(_generateWeekProgress.HasError ? "bg-danger" : "") progress-bar-striped @(!_generateWeekProgress.IsComplete ? "progress-bar-animated" : "")"
                     style="width:@(_generateWeekProgress.TotalPosts > 0 ? (int)(_generateWeekProgress.CompletedPosts * 100.0 / _generateWeekProgress.TotalPosts) : 0)%"></div>
            </div>
            <small class="text-muted">@_generateWeekProgress.Stage</small>
        </div>
        @if (_generateWeekProgress.IsComplete)
        {
            <button class="btn btn-sm btn-outline-secondary" @onclick="DismissGenerateWeekProgress">Dismiss</button>
        }
    </div>
}

<!-- Calendar Grid -->
@if (_schedule == null)
{
    <div class="text-center py-5"><span class="spinner-border"></span></div>
}
else if (_viewMode == ViewMode.Month)
{
    <div class="calendar-wrapper">
        <div class="calendar-grid">
            <!-- Day headers -->
            @foreach (var day in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
            {
                <div class="calendar-header-cell">@day</div>
            }

            <!-- Empty leading cells -->
            @for (var i = 0; i < LeadingBlanks; i++)
            {
                <div class="calendar-cell calendar-cell--empty"></div>
            }

            <!-- Day cells -->
            @foreach (var cell in CalendarCells)
            {
                <div class="calendar-cell @(cell.IsToday ? "calendar-cell--today" : "") @(cell.IsCurrentWeek && !cell.IsToday ? "calendar-cell--this-week" : "")">
                    <div class="calendar-cell__header">
                        <span class="calendar-day-number @(cell.IsToday ? "fw-bold text-primary" : "")">@cell.Day</span>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-outline-success calendar-action-btn"
                                    title="Auto-assign top post"
                                    @onclick="() => AutoAssignDay(cell.Date)">&#9889;</button>
                            <button class="btn btn-sm btn-outline-secondary calendar-action-btn"
                                    title="Pick a post"
                                    @onclick="() => OpenAddPost(cell.Date)">+</button>
                        </div>
                    </div>

                    @foreach (var post in cell.Posts)
                    {
                        var postCapture = post;
                        <div class="calendar-post-item"
                             title="@postCapture.Title"
                             @onclick="() => GoToPost(postCapture.SourcePostId)">
                            <div class="calendar-post-item__title">@TruncateTitle(postCapture.Title)</div>
                            <div class="d-flex gap-1 flex-wrap mt-1">
                                <span class="badge @GetStatusBadgeClass(postCapture)" style="font-size:0.6rem">@GetStatusLabel(postCapture)</span>
                                <span class="badge bg-secondary" style="font-size:0.6rem">@postCapture.Community</span>
                            </div>
                            <div class="calendar-post-meta">
                                <span>&#9650; @postCapture.Score</span>
                                <span>@postCapture.WordCount w</span>
                                @if (!postCapture.IsProcessed && postCapture.IsPosted != true && postCapture.SourcePostStatus != SourcePostStatus.Processing)
                                {
                                    <button class="btn btn-link p-0" style="font-size:0.7rem;color:var(--accent-warning);"
                                            title="Process with AI"
                                            @onclick:stopPropagation
                                            @onclick="() => OpenProcessAI(postCapture.SourcePostId)">
                                        <i class="bi bi-cpu"></i>
                                    </button>
                                }
                                else if (postCapture.VideoStatus != VideoStatus.Generated && postCapture.IsPosted != true)
                                {
                                    <button class="btn btn-link p-0" style="font-size:0.7rem;color:var(--accent-success);"
                                            title="Generate Video"
                                            @onclick:stopPropagation
                                            @onclick="() => OpenGenerateDialog(postCapture)">
                                        <i class="bi bi-film"></i>
                                    </button>
                                }
                                <button class="btn btn-link p-0 text-danger remove-btn"
                                        title="Remove"
                                        @onclick:stopPropagation
                                        @onclick="() => RemoveEntry(postCapture.ScheduledPostId)">&#xD7;</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}
else
{
    <WeekGrid WeekStart="_weekStart"
              Schedule="_schedule"
              OnAutoAssign="AutoAssignDay"
              OnAddPost="OpenAddPost"
              OnNavigate="GoToPost"
              OnRemove="RemoveEntry"
              OnProcessAI="OpenProcessAI"
              OnGenerate="OpenGenerateDialog"
              AiProgressStages="_aiProgressStages" />
}

<!-- Add Post Panel (slide-in at bottom of page) -->
@if (_addPostDate.HasValue)
{
    <div class="add-post-overlay">
        <div class="card shadow">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>Add post for @_addPostDate.Value.ToString("MMM d, yyyy")</span>
                <button class="btn-close" @onclick="CloseAddPost"></button>
            </div>
            <div class="card-body" style="max-height:400px;overflow-y:auto">
                @if (_availablePosts == null)
                {
                    <div class="text-center"><span class="spinner-border spinner-border-sm"></span></div>
                }
                else if (!_availablePosts.Any())
                {
                    <p class="text-muted">No unposted posts available.</p>
                }
                else
                {
                    <input type="text" class="form-control form-control-sm mb-2"
                           placeholder="Search posts..."
                           @bind="_postPickerSearch" @bind:event="oninput" />

                    @foreach (var post in FilteredAvailablePosts)
                    {
                        var postCapture = post;
                        <div class="post-pick-item d-flex justify-content-between align-items-center p-2 border-bottom">
                            <div>
                                <div class="fw-semibold" style="font-size:0.85rem">@postCapture.Title</div>
                                <small class="text-muted">@postCapture.Community &bull; &#9650; @postCapture.Score &bull; @postCapture.WordCount w</small>
                            </div>
                            <button class="btn btn-sm btn-primary ms-2" @onclick="() => AddPost(_addPostDate!.Value, postCapture.Id)">
                                Add
                            </button>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

