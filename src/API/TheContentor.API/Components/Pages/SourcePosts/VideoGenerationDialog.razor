@using MediatR
@using TheContentor.Application.Features.ProcessedPosts.Commands
@using TheContentor.Application.Features.Assets.Queries
@using TheContentor.Application.Features.Assets.Models
@inject IMediator Mediator

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Generate Video</h5>
                    <button type="button" class="btn-close" @onclick="Close" disabled="@_isGenerating"></button>
                </div>
                <div class="modal-body">
                    @if (_isLoading)
                    {
                        <div class="text-center">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading assets...</span>
                            </div>
                        </div>
                    }
                    else if (_assets.Count == 0)
                    {
                        <div class="alert alert-warning">
                            No active video assets found. Please upload video assets first.
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <small class="text-muted d-block mb-2">
                                Select one or more video assets. They will be concatenated and cut to match the audio duration for each part.
                            </small>
                            <div class="asset-pick-grid">
                                @foreach (var asset in _assets)
                                {
                                    var isSelected = _selectedAssetIds.Contains(asset.Id);
                                    <div class="asset-pick-card @(isSelected ? "selected" : "")"
                                         @key="asset.Id"
                                         @onclick="() => ToggleAssetCard(asset.Id)"
                                         title="@asset.FileName">
                                        <video src="@(asset.SasUri + "#t=0.5")" muted preload="metadata"></video>
                                        <div class="pick-info">
                                            <div class="pick-name">@(asset.Title ?? asset.FileName)</div>
                                            <div class="pick-meta">
                                                @if (asset.Duration.HasValue)
                                                {
                                                    <span>@asset.Duration.Value.ToString(@"mm\:ss")</span>
                                                }
                                                @if (asset.ContentTag.HasValue)
                                                {
                                                    <span>@asset.ContentTag.Value</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            @if (_selectedAssetIds.Count > 0)
                            {
                                <div class="mt-2">
                                    <small class="text-success">@_selectedAssetIds.Count asset(s) selected</small>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="Close" disabled="@_isGenerating">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="GenerateVideo"
                            disabled="@(_isGenerating || _selectedAssetIds.Count == 0 || _isLoading)">
                        @if (_isGenerating)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span> Generating...</span>
                        }
                        else
                        {
                            <span>Generate</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public Guid? ProcessedPostId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnGenerated { get; set; }

    private List<AssetDto> _assets = new();
    private HashSet<Guid> _selectedAssetIds = new();
    private bool _isGenerating = false;
    private bool _isLoading = false;

    protected override async Task OnParametersSetAsync()
    {
        if (IsVisible && !_isLoading && _assets.Count == 0)
        {
            await LoadAssets();
        }
    }

    private async Task LoadAssets()
    {
        _isLoading = true;
        try
        {
            var allAssets = await Mediator.Send(new GetAssetListQuery(ActiveOnly: true));
            _assets = allAssets.Where(a => a.IsActive).ToList();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleAssetCard(Guid assetId)
    {
        if (!_selectedAssetIds.Remove(assetId))
            _selectedAssetIds.Add(assetId);
    }

    private async Task GenerateVideo()
    {
        if (ProcessedPostId == null || _selectedAssetIds.Count == 0) return;

        _isGenerating = true;
        try
        {
            await Mediator.Send(new GenerateVideoCommand(ProcessedPostId.Value, _selectedAssetIds.ToList()));
            await OnGenerated.InvokeAsync();
            await Close();
        }
        finally
        {
            _isGenerating = false;
        }
    }

    private async Task Close()
    {
        if (!_isGenerating)
        {
            _selectedAssetIds.Clear();
            await OnClose.InvokeAsync();
        }
    }
}
