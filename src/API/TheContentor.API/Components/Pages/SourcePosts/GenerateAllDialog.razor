@using MediatR
@using TheContentor.Application.Features.ProcessedPosts.Commands
@using TheContentor.Application.Features.ProcessedPosts.Models
@using TheContentor.Application.Features.Assets.Queries
@using TheContentor.Application.Features.Assets.Models
@using TheContentor.Domain.Enums
@inject IMediator Mediator

@if (IsVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Generate Video</h5>
                    <button type="button" class="btn-close" @onclick="Close" disabled="@_isGenerating"></button>
                </div>
                <div class="modal-body">
                    <h6 class="fw-bold mb-3">Voice Settings</h6>
                    <div class="mb-3">
                        <label class="form-label fw-bold">TTS Engine</label>
                        <select class="form-select" @bind="_engine" @bind:after="OnEngineChanged" disabled="@_isGenerating">
                            <option value="@TtsEngine.EdgeTTS">Edge TTS (Microsoft Neural)</option>
                            <option value="@TtsEngine.Kokoro">Kokoro TTS (Local)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Voice</label>
                        @if (_engine == TtsEngine.EdgeTTS)
                        {
                            <select class="form-select" @bind="_selectedVoice" disabled="@_isGenerating">
                                <option value="en-US-GuyNeural">Male (Guy - US English)</option>
                                <option value="en-US-MichelleNeural">Female (Michelle - US English)</option>
                                <option value="en-US-ChristopherNeural">Male (Christopher - US English)</option>
                                <option value="en-US-JennyNeural">Female (Jenny - US English)</option>
                            </select>
                        }
                        else
                        {
                            <select class="form-select" @bind="_selectedVoice" disabled="@_isGenerating">
                                <option value="af_heart">Heart (Female - American)</option>
                                <option value="af_sky">Sky (Female - American)</option>
                                <option value="af_bella">Bella (Female - American)</option>
                                <option value="am_adam">Adam (Male - American)</option>
                                <option value="am_michael">Michael (Male - American)</option>
                                <option value="bf_emma">Emma (Female - British)</option>
                                <option value="bm_george">George (Male - British)</option>
                            </select>
                        }
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">@(_engine == TtsEngine.Kokoro ? "Speed" : "Rate"): @_rate%</label>
                        <input type="range" class="form-range" min="-50" max="50" @bind="_rate" @bind:event="oninput" disabled="@_isGenerating" />
                        <small class="text-muted">Adjust speech speed (-50% slower to +50% faster)</small>
                    </div>
                    @if (_engine == TtsEngine.EdgeTTS)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-bold">Pitch: @_pitch Hz</label>
                            <input type="range" class="form-range" min="-20" max="20" @bind="_pitch" @bind:event="oninput" disabled="@_isGenerating" />
                            <small class="text-muted">Adjust voice pitch (-20Hz lower to +20Hz higher)</small>
                        </div>
                    }

                    <hr />

                    <h6 class="fw-bold mb-3">Background Video</h6>
                    @if (_isLoading)
                    {
                        <div class="text-center">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading assets...</span>
                            </div>
                        </div>
                    }
                    else if (_assets.Count == 0)
                    {
                        <div class="alert alert-warning">
                            No active video assets found. Please upload video assets first.
                        </div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <small class="text-muted d-block mb-2">
                                Select one or more video assets. They will be concatenated and cut to match the audio duration for each part.
                            </small>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <label class="form-label mb-0 fw-bold" style="white-space:nowrap;">Filter by tag:</label>
                                <select class="form-select form-select-sm" style="width:auto;" @bind="_filterTag" disabled="@_isGenerating">
                                    <option value="">All</option>
                                    @foreach (var tag in Enum.GetValues<AssetContentTag>())
                                    {
                                        <option value="@tag">@tag</option>
                                    }
                                </select>
                            </div>
                            <div class="asset-pick-grid">
                                @foreach (var asset in FilteredAssets)
                                {
                                    var isSelected = _selectedAssetIds.Contains(asset.Id);
                                    <div class="asset-pick-card @(isSelected ? "selected" : "")"
                                         @key="asset.Id"
                                         @onclick="() => ToggleAssetCard(asset.Id)"
                                         title="@asset.FileName">
                                        <video src="@(asset.SasUri + "#t=0.5")" muted preload="metadata"></video>
                                        <div class="pick-info">
                                            <div class="pick-name">@(asset.Title ?? asset.FileName)</div>
                                            <div class="pick-meta">
                                                @if (asset.Duration.HasValue)
                                                {
                                                    <span>@asset.Duration.Value.ToString(@"mm\:ss")</span>
                                                }
                                                @if (asset.Quality.HasValue)
                                                {
                                                    <span>@(asset.Quality.Value.ToString().TrimStart('P') + "p")</span>
                                                }
                                                @if (asset.ContentTag.HasValue)
                                                {
                                                    <span>@asset.ContentTag.Value</span>
                                                }
                                            </div>
                                            <div class="pick-meta" style="font-size:0.65rem;opacity:0.7;">
                                                @if (asset.LastUsedAt.HasValue)
                                                {
                                                    <span>Used @FormatTimeAgo(asset.LastUsedAt.Value)</span>
                                                }
                                                else
                                                {
                                                    <span>Never used</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            @if (_selectedAssetIds.Count > 0)
                            {
                                <div class="mt-2">
                                    <small class="text-success">@_selectedAssetIds.Count asset(s) selected</small>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="Close" disabled="@_isGenerating">Cancel</button>
                    <button type="button" class="btn btn-success" @onclick="Generate"
                            disabled="@(_isGenerating || _selectedAssetIds.Count == 0 || _isLoading)">
                        @if (_isGenerating)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span> Generating...</span>
                        }
                        else
                        {
                            <span>Generate</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public Guid? ProcessedPostId { get; set; }
    [Parameter] public NarratorGender Gender { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnGenerated { get; set; }

    private TtsEngine _engine = TtsEngine.EdgeTTS;
    private string _selectedVoice = string.Empty;
    private int _rate = 50;
    private int _pitch = 20;
    private List<AssetDto> _assets = new();
    private HashSet<Guid> _selectedAssetIds = new();
    private bool _isGenerating = false;
    private bool _isLoading = false;
    private AssetContentTag? _filterTag;

    private IEnumerable<AssetDto> FilteredAssets => _filterTag.HasValue
        ? _assets.Where(a => a.ContentTag == _filterTag.Value)
        : _assets;

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrEmpty(_selectedVoice))
        {
            _selectedVoice = Gender == NarratorGender.Male ? "en-US-GuyNeural" : "en-US-MichelleNeural";
        }

        if (IsVisible && !_isLoading && _assets.Count == 0)
        {
            await LoadAssets();
        }
    }

    private void OnEngineChanged()
    {
        _selectedVoice = _engine == TtsEngine.EdgeTTS
            ? (Gender == NarratorGender.Male ? "en-US-GuyNeural" : "en-US-MichelleNeural")
            : (Gender == NarratorGender.Male ? "am_adam" : "af_heart");
        _rate = _engine == TtsEngine.Kokoro ? 25 : 50;
        _pitch = 0;
    }

    private async Task LoadAssets()
    {
        _isLoading = true;
        try
        {
            var assets = await Mediator.Send(new GetAssetListQuery(ActiveOnly: true));
            _assets = assets
                .OrderBy(a => a.LastUsedAt.HasValue ? 1 : 0)
                .ThenBy(a => a.LastUsedAt)
                .ToList();
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleAssetCard(Guid assetId)
    {
        if (!_selectedAssetIds.Remove(assetId))
            _selectedAssetIds.Add(assetId);
    }

    private async Task Generate()
    {
        if (ProcessedPostId == null || _selectedAssetIds.Count == 0) return;

        _isGenerating = true;
        try
        {
            var ttsSettings = new TtsSettingsModel
            {
                Engine = _engine,
                Voice = _selectedVoice,
                Rate = _rate,
                Pitch = _pitch
            };

            await Mediator.Send(new GenerateAllCommand(ProcessedPostId.Value, ttsSettings, _selectedAssetIds.ToList()));
            await OnGenerated.InvokeAsync();
            _isGenerating = false;
            await Close();
        }
        catch
        {
            _isGenerating = false;
            throw;
        }
    }

    private async Task Close()
    {
        if (!_isGenerating)
        {
            _selectedAssetIds.Clear();
            _filterTag = null;
            await OnClose.InvokeAsync();
        }
    }

    private static string FormatTimeAgo(DateTime utcDate)
    {
        var span = DateTime.UtcNow - utcDate;
        if (span.TotalMinutes < 1) return "just now";
        if (span.TotalHours < 1) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalDays < 1) return $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 30) return $"{(int)span.TotalDays}d ago";
        return utcDate.ToString("MMM d, yyyy");
    }
}