@page "/source-posts/{Id:guid}"

<style>
    .video-preview-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.88);
        z-index: 1055;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .video-preview-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
    }

    .iphone-frame {
        position: relative;
        width: 553px;
        height: 1130px;
        background: linear-gradient(160deg, #2c2c2e, #1c1c1e);
        border-radius: 50px;
        padding: 12px;
        box-shadow:
            inset 0 0 0 1.5px #48484a,
            0 0 0 1px #111,
            0 30px 70px rgba(0, 0, 0, 0.8);
    }

    .iphone-vol-up {
        position: absolute;
        left: -3px;
        top: 110px;
        width: 3px;
        height: 30px;
        background: #48484a;
        border-radius: 2px 0 0 2px;
    }

    .iphone-vol-down {
        position: absolute;
        left: -3px;
        top: 155px;
        width: 3px;
        height: 30px;
        background: #48484a;
        border-radius: 2px 0 0 2px;
    }

    .iphone-mute {
        position: absolute;
        left: -3px;
        top: 75px;
        width: 3px;
        height: 22px;
        background: #48484a;
        border-radius: 2px 0 0 2px;
    }

    .iphone-power {
        position: absolute;
        right: -3px;
        top: 140px;
        width: 3px;
        height: 60px;
        background: #48484a;
        border-radius: 0 2px 2px 0;
    }

    .iphone-screen {
        width: 100%;
        height: 100%;
        background: #000;
        border-radius: 40px;
        overflow: hidden;
        position: relative;
    }

    .iphone-notch {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 130px;
        height: 32px;
        background: #1c1c1e;
        border-radius: 0 0 22px 22px;
        z-index: 10;
    }

    .iphone-video {
        width: 100%;
        height: 100%;
        display: block;
    }

    .iphone-home-bar {
        position: absolute;
        bottom: 7px;
        left: 50%;
        transform: translateX(-50%);
        width: 110px;
        height: 4px;
        background: rgba(255, 255, 255, 0.45);
        border-radius: 2px;
        z-index: 10;
    }

    .video-preview-close-btn {
        position: absolute;
        top: -14px;
        right: -14px;
        width: 32px;
        height: 32px;
        background: #fff;
        border: none;
        border-radius: 50%;
        font-size: 18px;
        font-weight: bold;
        line-height: 1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
        color: #333;
        padding: 0;
    }

    .video-preview-close-btn:hover {
        background: #f0f0f0;
    }
</style>
@using MediatR
@using Microsoft.AspNetCore.SignalR
@using Microsoft.AspNetCore.SignalR.Client
@using TheContentor.Application.Features.SourcePosts.Models
@using TheContentor.Application.Features.SourcePosts.Commands
@using TheContentor.Application.Features.SourcePosts.Queries
@using TheContentor.Application.Features.ProcessedPosts.Commands
@using TheContentor.Application.Features.ProcessedPosts.Models
@using TheContentor.Domain.Enums
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode InteractiveServer

<GenerateAllDialog IsVisible="_showGenerateDialog"
                   ProcessedPostId="Post?.ProcessedPost?.Id"
                   Gender="Post?.ProcessedPost?.NarratorGender ?? NarratorGender.Male"
                   OnClose="CloseGenerateDialog"
                   OnGenerated="OnGenerated" />

@if (_previewVideoUrl != null)
{
    <div class="video-preview-overlay" @onclick="CloseVideoPreview">
        <div class="video-preview-container" @onclick:stopPropagation>
            <div style="position: relative;">
                <div class="iphone-frame">
                    <div class="iphone-mute"></div>
                    <div class="iphone-vol-up"></div>
                    <div class="iphone-vol-down"></div>
                    <div class="iphone-power"></div>
                    <div class="iphone-screen">
                        <div class="iphone-notch"></div>
                        <video class="iphone-video" controls autoplay playsinline>
                            <source src="@_previewVideoUrl" type="video/mp4" />
                        </video>
                        <div class="iphone-home-bar"></div>
                    </div>
                </div>
            </div>
            <small class="text-white-50">Click outside to close</small>
        </div>
    </div>
}

@if (Post == null)
{
    <div class="container mt-4">
        <p><em>Loading...</em></p>
    </div>
}
else
{
    <div class="container mt-4 pb-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2>@Post.Title</h2>
                <small class="text-muted">
                    Posted by u/@Post.AuthorName in r/@Post.Community
                    • @Post.CreatedUtc.ToString("f")
                </small>
            </div>
            <div>
                <button class="btn btn-outline-secondary me-2" @onclick="GoBack">Back to List</button>
                @if (!_isEditing)
                {
                    <button class="btn btn-primary" @onclick="StartEditing">Edit</button>
                }
                else
                {
                    <button class="btn btn-success me-2" @onclick="UpdateProcessedPost">Save</button>
                    <button class="btn btn-secondary" @onclick="CancelEditing">Cancel</button>
                }
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-light fw-bold">Post Info</div>
                    <div class="card-body">
                        <div class="mb-3">
                            <span class="badge bg-secondary me-1">@Post.Platform</span>
                            <span class="badge bg-info me-1">@Post.Score points</span>
                            @if (Post.UpvoteRatio.HasValue)
                            {
                                <span class="badge bg-info me-1">@(Post.UpvoteRatio.Value.ToString("P0")) Upvoted</span>
                            }
                            <span class="badge bg-dark me-1">@Post.WordCount words</span>
                            <span class="badge @GetStatusClass(Post.Status) me-1">@Post.Status</span>
                        </div>
                        <div class="mb-3 d-flex gap-2 flex-wrap">
                            <a href="@Post.ExternalUrl" target="_blank" class="btn btn-sm btn-outline-primary">View on @Post.Platform</a>
                            @if (Post.ProcessedPost != null)
                            {
                                <button class="btn btn-sm @(Post.ProcessedPost.IsPosted ? "btn-success" : "btn-outline-success")"
                                        @onclick="TogglePostedStatus"
                                        disabled="@_isEditing">
                                    <i class="bi @(Post.ProcessedPost.IsPosted ? "bi-check2-circle" : "bi-circle")"></i>
                                    @(Post.ProcessedPost.IsPosted ? "Posted" : "Mark as Posted")
                                </button>
                            }
                            <button class="btn btn-sm @(Post.Status == SourcePostStatus.Skipped ? "btn-warning" : "btn-outline-warning")"
                                    @onclick="ToggleSkip"
                                    disabled="@_isEditing"
                                    title="@(Post.Status == SourcePostStatus.Skipped ? "Restore post — it will be eligible for scheduling again" : "Mark as not good enough — excludes from auto-scheduling")">
                                <i class="bi @(Post.Status == SourcePostStatus.Skipped ? "bi-arrow-counterclockwise" : "bi-x-circle")"></i>
                                @(Post.Status == SourcePostStatus.Skipped ? "Restore" : "Skip")
                            </button>
                        </div>
                        <hr/>
                        <div class="post-content" style="white-space: pre-wrap; max-height: 500px; overflow-y: auto; font-size: 0.9rem;">
                            @Post.RawText
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2 mb-4">
                     <button type="button" class="btn btn-warning" @onclick="ProcessWithAI" disabled="@(_isProcessing || _isEditing)">
                        @if (_isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span> Processing...</span>
                        }
                        else
                        {
                            <span>@(Post.Status == SourcePostStatus.Processed ? "Re-process with AI" : "Process with AI")</span>
                        }
                    </button>

                    @if (Post.ProcessedPost != null && Post.Status == SourcePostStatus.Processed)
                    {
                        <div class="mt-3">
                            @if (_currentProgress != null)
                            {
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <small class="fw-bold">@_currentProgress.Stage</small>
                                        <small>@(_currentProgress.ProgressPercent)%</small>
                                    </div>
                                    <div class="progress" style="height: 20px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated @(_currentProgress.HasError ? "bg-danger" : "bg-primary")"
                                             role="progressbar"
                                             style="width: @(_currentProgress.ProgressPercent)%"
                                             aria-valuenow="@_currentProgress.ProgressPercent"
                                             aria-valuemin="0"
                                             aria-valuemax="100">
                                        </div>
                                    </div>
                                    <small class="text-muted">@_currentProgress.Message</small>
                                    @if (_currentProgress.HasError && !string.IsNullOrEmpty(_currentProgress.ErrorMessage))
                                    {
                                        <div class="mt-1">
                                            <small class="text-danger">@_currentProgress.ErrorMessage</small>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="d-flex gap-2 mb-2">
                                @if (Post.ProcessedPost.TtsStatus == TtsStatus.Generated)
                                {
                                    <span class="badge bg-success">TTS Generated</span>
                                }
                                @if (Post.ProcessedPost.VideoStatus == VideoStatus.Generated)
                                {
                                    <span class="badge bg-success">Video Generated</span>
                                }
                            </div>

                            <button type="button" class="btn btn-success w-100"
                                    @onclick="ShowGenerateDialog"
                                    disabled="@(_isProcessing || _isEditing || IsGenerating)">
                                <span>@(HasPreviousGeneration() ? "Re-generate" : "Generate")</span>
                            </button>

                            @if (IsGenerating)
                            {
                                <button type="button" class="btn btn-outline-danger w-100 mt-2"
                                        @onclick="CancelGeneration"
                                        disabled="@(_isProcessing || _isEditing || _isCanceling)">
                                    @if (_isCanceling)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        <span> Canceling...</span>
                                    }
                                    else
                                    {
                                        <span>Cancel Generation</span>
                                    }
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-8">
                @if (Post.ProcessedPost != null)
                {
                    <div class="card mb-4 border-primary shadow-sm">
                        <div class="card-header bg-primary text-white fw-bold">
                            AI Processed Content
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Post Title (Social Media)</label>
                                @if (_isEditing)
                                {
                                    <input type="text" class="form-control" @bind="Post.ProcessedPost.Title" />
                                }
                                else
                                {
                                    <div class="p-2 border rounded bg-light">@Post.ProcessedPost.Title</div>
                                }
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Post Description (Social Media)</label>
                                @if (_isEditing)
                                {
                                    <textarea class="form-control" rows="3" @bind="Post.ProcessedPost.Description"></textarea>
                                }
                                else
                                {
                                    <div class="p-2 border rounded bg-light" style="white-space: pre-wrap;">@Post.ProcessedPost.Description</div>
                                    @if (!string.IsNullOrEmpty(Post.ProcessedPost.DescriptionAudioBlobPath?.SasUrl))
                                    {
                                        <div class="mt-2">
                                            <audio controls class="w-100">
                                                <source src="@Post.ProcessedPost.DescriptionAudioBlobPath.SasUrl" type="audio/mpeg">
                                                Your browser does not support the audio element.
                                            </audio>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Post Hashtags</label>
                                @if (_isEditing)
                                {
                                    <input type="text" class="form-control" @bind="_hashtagsText" placeholder="Enter hashtags separated by comma..." />
                                }
                                else
                                {
                                    <div class="p-2 border rounded bg-light">@_hashtagsText</div>
                                }
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Narrator Gender</label>
                                @if (_isEditing)
                                {
                                    <select class="form-select" @bind="Post.ProcessedPost.NarratorGender">
                                        @foreach (var gender in Enum.GetValues<NarratorGender>())
                                        {
                                            <option value="@gender">@gender</option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <div class="p-2 border rounded bg-light">@Post.ProcessedPost.NarratorGender</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0">Content Parts</h4>
                        @if (_isEditing)
                        {
                            <button class="btn btn-outline-primary btn-sm" @onclick="AddPart">+ Add Part</button>
                        }
                    </div>

                    @foreach (var part in Post.ProcessedPost.Parts.OrderBy(p => p.Part))
                    {
                        <div class="card mb-3 border-secondary shadow-sm" @key="part">
                            <div class="card-header bg-light d-flex justify-content-between align-items-center py-2">
                                <div class="d-flex align-items-center">
                                    <span class="badge bg-secondary me-3">Part @part.Part</span>
                                    @if (_isEditing)
                                    {
                                        <div class="d-flex align-items-center">
                                            <small class="me-2 fw-bold">Order:</small>
                                            <input type="number" class="form-control form-control-sm" style="width: 70px;" @bind="part.Part" />
                                        </div>
                                    }
                                </div>
                                <div class="d-flex gap-1">
                                    @if (!_isEditing)
                                    {
                                        @if (!string.IsNullOrEmpty(part.VideoBlobPath?.SasUrl))
                                        {
                                            <button class="btn btn-sm btn-success"
                                                    @onclick="() => OpenVideoPreview(part.VideoBlobPath!.SasUrl)">
                                                <i class="bi bi-phone"></i> Preview Video
                                            </button>
                                        }

                                        <button class="btn btn-sm @(_copiedPartId == part.Id ? "btn-success" : "btn-outline-secondary")"
                                                @onclick="() => CopyPartToClipboard(part)">
                                            @if (_copiedPartId == part.Id)
                                            {
                                                <i class="bi bi-check2"></i> <span>Copied!</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-clipboard"></i> <span>Copy for Social</span>
                                            }
                                        </button>
                                    }
                                    @if (_isEditing)
                                    {
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => RemovePart(part)">
                                            Remove
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Processed Text</label>
                                    @if (_isEditing)
                                    {
                                        <textarea class="form-control" rows="4" @bind="part.ProcessedText"></textarea>
                                    }
                                    else
                                    {
                                        <div class="p-2 border rounded bg-light" style="white-space: pre-wrap;">@part.ProcessedText</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else if (Post.Status == SourcePostStatus.Raw)
                {
                    <div class="alert alert-info">
                        This post hasn't been processed by AI yet. Click "Process with AI" to generate social media content.
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private SourcePostDetailsDto? Post { get; set; }
    private string _hashtagsText = "";
    private Dictionary<ProcessedPostPartDto, string> _partHashtags = new();
    private bool _isProcessing = false;
    private bool _isEditing = false;
    private bool _isCanceling = false;
    private bool _showGenerateDialog = false;
    private string? _previewVideoUrl;
    private HubConnection? _hubConnection;
    private GenerationProgressModel? _currentProgress;
    private Guid? _copiedPartId;

    private bool IsGenerating => Post?.ProcessedPost?.TtsStatus == TtsStatus.InProgress
                              || Post?.ProcessedPost?.VideoStatus == VideoStatus.InProgress;

    protected override async Task OnInitializedAsync()
    {
        await LoadPost();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/video-generation"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<GenerationProgressModel>("ProgressUpdate", async (progress) =>
        {
            _currentProgress = progress;
            if (progress.IsComplete)
            {
                await LoadPost();
                _currentProgress = null;
            }
            await InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();

        if (Post?.ProcessedPost != null)
        {
            await _hubConnection.InvokeAsync("JoinPostGroup", Post.ProcessedPost.Id);
        }
    }

    private async Task LoadPost()
    {
        Post = await Mediator.Send(new GetSourcePostDetailsQuery(Id));
        if (Post?.ProcessedPost != null)
        {
            _hashtagsText = string.Join(", ", Post.ProcessedPost.Hashtags);
            _partHashtags.Clear();
            foreach (var part in Post.ProcessedPost.Parts)
            {
                _partHashtags[part] = string.Join(", ", part.Hashtags);
            }
        }
    }

    private async Task ProcessWithAI()
    {
        if (Post == null) return;
        _isProcessing = true;
        try
        {
            await Mediator.Send(new ProcessSourcePostCommand(Post.Id));
            await LoadPost();
            _isEditing = false;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private void StartEditing()
    {
        _isEditing = true;
    }

    private async Task CancelEditing()
    {
        await LoadPost();
        _isEditing = false;
    }

    private async Task UpdateProcessedPost()
    {
        if (Post?.ProcessedPost == null) return;

        var command = new UpdateProcessedPostCommand(
            Post.ProcessedPost.Id,
            Post.ProcessedPost.Title,
            Post.ProcessedPost.Description,
            _hashtagsText.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim()).ToList(),
            Post.ProcessedPost.NarratorGender,
            Post.ProcessedPost.Parts.Select(p => new UpdateProcessedPostPartDto(
                p.Id,
                p.ProcessedText,
                _partHashtags.GetValueOrDefault(p, "").Split(',', StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim()).ToList(),
                p.PublishedTo,
                p.Part
            )).ToList()
        );

        await Mediator.Send(command);
        await LoadPost();
        _isEditing = false;
    }

    private void AddPart()
    {
        if (Post?.ProcessedPost == null) return;

        var newPart = new ProcessedPostPartDto
        {
            Part = Post.ProcessedPost.Parts.Any() ? Post.ProcessedPost.Parts.Max(p => p.Part) + 1 : 1,
            ProcessedText = "",
            Hashtags = [],
            PublishedTo = []
        };

        Post.ProcessedPost.Parts.Add(newPart);
        _partHashtags[newPart] = "";
    }

    private void RemovePart(ProcessedPostPartDto part)
    {
        Post?.ProcessedPost?.Parts.Remove(part);
        _partHashtags.Remove(part);
    }

    private void TogglePlatform(ProcessedPostPartDto part, SocialPlatform platform, object? isChecked)
    {
        if (!_isEditing) return;

        if (isChecked is true)
        {
            if (!part.PublishedTo.Contains(platform))
                part.PublishedTo.Add(platform);
        }
        else
        {
            part.PublishedTo.Remove(platform);
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/source-posts");
    }

    private string GetStatusClass(SourcePostStatus status) => status switch
    {
        SourcePostStatus.Raw => "bg-info",
        SourcePostStatus.Processed => "bg-primary",
        SourcePostStatus.Approved => "bg-success",
        SourcePostStatus.Rejected => "bg-danger",
        _ => "bg-secondary"
    };

    private void ShowGenerateDialog()
    {
        _showGenerateDialog = true;
    }

    private void OpenVideoPreview(string url)
    {
        _previewVideoUrl = url;
    }

    private void CloseVideoPreview()
    {
        _previewVideoUrl = null;
    }

    private async Task CloseGenerateDialog()
    {
        _showGenerateDialog = false;
        await Task.CompletedTask;
    }

    private async Task OnGenerated()
    {
        await LoadPost();
    }

    private bool HasPreviousGeneration()
    {
        return Post?.ProcessedPost?.TtsStatus == TtsStatus.Generated
            || Post?.ProcessedPost?.VideoStatus == VideoStatus.Generated;
    }

    private async Task CancelGeneration()
    {
        if (Post?.ProcessedPost == null) return;
        _isCanceling = true;
        try
        {
            await Mediator.Send(new CancelGenerationCommand(Post.ProcessedPost.Id));
            _currentProgress = null;
            await LoadPost();
        }
        finally
        {
            _isCanceling = false;
        }
    }

    private async Task CopyPartToClipboard(ProcessedPostPartDto part)
    {
        if (Post?.ProcessedPost == null) return;

        var hashtags = Post.ProcessedPost.Hashtags
            .Concat(part.Hashtags)
            .Select(t => t.Trim().StartsWith('#') ? t.Trim() : $"#{t.Trim()}")
            .Where(t => t.Length > 1)
            .Distinct();

        var hashtagsLine = string.Join(" ", hashtags);

        var prefix = Post.ProcessedPost.Parts.Count == 1 ? "[Full Story]" : $"[Part {part.Part}]";
        var text = $"{prefix} {Post.ProcessedPost.Title}";
        if (!string.IsNullOrWhiteSpace(hashtagsLine))
            text += $"\n\n{hashtagsLine}";

        await JS.InvokeVoidAsync("copyToClipboard", text);

        _copiedPartId = part.Id;
        StateHasChanged();
        await Task.Delay(2000);
        _copiedPartId = null;
        StateHasChanged();
    }

    private async Task TogglePostedStatus()
    {
        if (Post?.ProcessedPost == null) return;
        var newValue = !Post.ProcessedPost.IsPosted;
        await Mediator.Send(new MarkProcessedPostAsPostedCommand(Post.ProcessedPost.Id, newValue));
        Post.ProcessedPost.IsPosted = newValue;
        StateHasChanged();
    }

    private async Task ToggleSkip()
    {
        if (Post == null) return;
        await Mediator.Send(new ToggleSkipSourcePostCommand(Post.Id));
        Post.Status = Post.Status == SourcePostStatus.Skipped
            ? SourcePostStatus.Raw
            : SourcePostStatus.Skipped;
        StateHasChanged();
    }

    private async Task QuickTogglePlatform(ProcessedPostPartDto part, SocialPlatform platform)
    {
        if (part.Id == null) return;

        var newValue = !part.PublishedTo.Contains(platform);
        await Mediator.Send(new TogglePartPlatformCommand(part.Id.Value, platform, newValue));

        if (newValue)
        {
            if (!part.PublishedTo.Contains(platform))
                part.PublishedTo.Add(platform);
        }
        else
        {
            part.PublishedTo.Remove(platform);
        }
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
