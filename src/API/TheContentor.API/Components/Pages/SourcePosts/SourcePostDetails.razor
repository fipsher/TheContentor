@page "/source-posts/{Id:guid}"

<style>
    .video-preview-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.88);
        z-index: 1055;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .video-preview-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
    }

    .iphone-frame {
        position: relative;
        width: 553px;
        height: 1130px;
        background: linear-gradient(160deg, #2c2c2e, #1c1c1e);
        border-radius: 50px;
        padding: 12px;
        box-shadow:
            inset 0 0 0 1.5px #48484a,
            0 0 0 1px #111,
            0 30px 70px rgba(0, 0, 0, 0.8);
    }

    .iphone-vol-up {
        position: absolute;
        left: -3px;
        top: 110px;
        width: 3px;
        height: 30px;
        background: #48484a;
        border-radius: 2px 0 0 2px;
    }

    .iphone-vol-down {
        position: absolute;
        left: -3px;
        top: 155px;
        width: 3px;
        height: 30px;
        background: #48484a;
        border-radius: 2px 0 0 2px;
    }

    .iphone-mute {
        position: absolute;
        left: -3px;
        top: 75px;
        width: 3px;
        height: 22px;
        background: #48484a;
        border-radius: 2px 0 0 2px;
    }

    .iphone-power {
        position: absolute;
        right: -3px;
        top: 140px;
        width: 3px;
        height: 60px;
        background: #48484a;
        border-radius: 0 2px 2px 0;
    }

    .iphone-screen {
        width: 100%;
        height: 100%;
        background: #000;
        border-radius: 40px;
        overflow: hidden;
        position: relative;
    }

    .iphone-notch {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 130px;
        height: 32px;
        background: #1c1c1e;
        border-radius: 0 0 22px 22px;
        z-index: 10;
    }

    .iphone-video {
        width: 100%;
        height: 100%;
        display: block;
    }

    .iphone-home-bar {
        position: absolute;
        bottom: 7px;
        left: 50%;
        transform: translateX(-50%);
        width: 110px;
        height: 4px;
        background: rgba(255, 255, 255, 0.45);
        border-radius: 2px;
        z-index: 10;
    }

    .video-preview-close-btn {
        position: absolute;
        top: -14px;
        right: -14px;
        width: 32px;
        height: 32px;
        background: #fff;
        border: none;
        border-radius: 50%;
        font-size: 18px;
        font-weight: bold;
        line-height: 1;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.4);
        color: #333;
        padding: 0;
    }

    .video-preview-close-btn:hover {
        background: #f0f0f0;
    }
</style>
@using MediatR
@using Microsoft.AspNetCore.SignalR
@using Microsoft.AspNetCore.SignalR.Client
@using TheContentor.Application.Features.SourcePosts.Models
@using TheContentor.Application.Features.SourcePosts.Commands
@using TheContentor.Application.Features.SourcePosts.Queries
@using TheContentor.Application.Features.ProcessedPosts.Commands
@using TheContentor.Application.Features.ProcessedPosts.Models
@using TheContentor.Domain.Enums
@using System.Linq
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode InteractiveServer

<GenerateAllDialog IsVisible="_showGenerateDialog"
                   ProcessedPostId="Post?.ProcessedPost?.Id"
                   Gender="Post?.ProcessedPost?.NarratorGender ?? NarratorGender.Male"
                   OnClose="CloseGenerateDialog"
                   OnGenerated="OnGenerated" />

@if (_previewVideoUrl != null)
{
    <div class="video-preview-overlay" @onclick="CloseVideoPreview">
        <div class="video-preview-container" @onclick:stopPropagation>
            <div style="position: relative;">
                <div class="iphone-frame">
                    <div class="iphone-mute"></div>
                    <div class="iphone-vol-up"></div>
                    <div class="iphone-vol-down"></div>
                    <div class="iphone-power"></div>
                    <div class="iphone-screen">
                        <div class="iphone-notch"></div>
                        <video class="iphone-video" controls autoplay playsinline>
                            <source src="@_previewVideoUrl" type="video/mp4" />
                        </video>
                        <div class="iphone-home-bar"></div>
                    </div>
                </div>
            </div>
            <small class="text-white-50">Click outside to close</small>
        </div>
    </div>
}

<!-- AI Process Settings Modal -->
@if (_showProcessModal)
{
    <div class="modal fade show" style="display:block;" tabindex="-1" @onclick="CloseProcessModal">
        <div class="modal-dialog modal-dialog-centered" style="max-width:420px;" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-cpu me-2" style="color:var(--accent-warning);"></i>
                        AI Processing Settings
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseProcessModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Processing Mode</label>
                        <div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" id="modeClassic"
                                       checked="@(_processingMode == ProcessingMode.Classic)"
                                       @onchange="() => _processingMode = ProcessingMode.Classic" />
                                <label class="form-check-label" for="modeClassic">
                                    <strong>Quick Process</strong><br />
                                    <small class="text-muted">Fast single-step analysis. Good for most posts.</small>
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" id="modeFullPipeline"
                                       checked="@(_processingMode == ProcessingMode.FullPipeline)"
                                       @onchange="() => _processingMode = ProcessingMode.FullPipeline" />
                                <label class="form-check-label" for="modeFullPipeline">
                                    <strong>Best Quality</strong><br />
                                    <small class="text-muted">Three-step AI refinement for maximum engagement. Takes longer.</small>
                                </label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" id="modeEnhance"
                                       checked="@(_processingMode == ProcessingMode.EnhanceExisting)"
                                       disabled="@(Post?.ProcessedPost == null)"
                                       @onchange="() => _processingMode = ProcessingMode.EnhanceExisting" />
                                <label class="form-check-label @(Post?.ProcessedPost == null ? "text-muted" : "")" for="modeEnhance">
                                    <strong>Refine Existing</strong>
                                    @if (Post?.ProcessedPost == null)
                                    {
                                        <span class="badge bg-secondary ms-1" style="font-size:0.7rem;">Requires existing content</span>
                                    }
                                    <br />
                                    <small class="text-muted">Run remaining steps on already-processed content without starting over.</small>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">LLM Provider</label>
                        <select class="form-select" @bind="_llmProvider">
                            <option value="@LlmProvider.Gemini">Google Gemini</option>
                            <option value="@LlmProvider.OpenAI">OpenAI ChatGPT</option>
                            <option value="@LlmProvider.Local">Local (Ollama)</option>
                        </select>
                    </div>

                    @if (_llmProvider == LlmProvider.Local)
                    {
                        <div class="mb-3">
                            <label class="form-label">Model Name</label>
                            <input type="text" class="form-control" placeholder="qwen2.5:7b"
                                   @bind="_localModelName" />
                            <div class="form-text">
                                Model must be pulled via <code>ollama pull &lt;model&gt;</code>.
                                Examples: <code>qwen2.5:7b</code>, <code>gemma3:9b</code>, <code>llama3.3:70b</code>
                            </div>
                        </div>
                    }

                    @if (_processingMode != ProcessingMode.EnhanceExisting)
                    {
                        <div class="mb-3">
                            <label class="form-label">Parts Count</label>
                            <div class="d-flex align-items-center gap-2">
                                <input type="number" class="form-control" style="width:90px;"
                                       @bind="_partsCount" min="1" max="20"
                                       disabled="@_partsCountAuto" />
                                <button class="auto-toggle @(_partsCountAuto ? "active" : "")"
                                        @onclick="() => _partsCountAuto = !_partsCountAuto">
                                    <i class="bi @(_partsCountAuto ? "bi-magic" : "bi-input-cursor")"></i>
                                    @(_partsCountAuto ? "Auto" : "Manual")
                                </button>
                            </div>
                        </div>
                        <div class="mb-1">
                            <label class="form-label">Words per Part</label>
                            <div class="d-flex align-items-center gap-2">
                                <input type="number" class="form-control" style="width:90px;"
                                       @bind="_wordsPerPart" min="50" max="2000"
                                       disabled="@_wordsPerPartAuto" />
                                <button class="auto-toggle @(_wordsPerPartAuto ? "active" : "")"
                                        @onclick="() => _wordsPerPartAuto = !_wordsPerPartAuto">
                                    <i class="bi @(_wordsPerPartAuto ? "bi-magic" : "bi-input-cursor")"></i>
                                    @(_wordsPerPartAuto ? "Auto" : "Manual")
                                </button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info py-2 px-3 mb-0" style="font-size:0.85rem;">
                            <i class="bi bi-stars me-1"></i>
                            Runs Steps 2 and 2.5 on your existing content — refines tone, hooks, and retention without restructuring.
                        </div>
                    }

                    @if (_processingMode == ProcessingMode.FullPipeline)
                    {
                        <div class="alert alert-warning py-2 px-3 mt-2 mb-0" style="font-size:0.85rem;">
                            <i class="bi bi-clock me-1"></i>
                            Runs three AI steps — takes approximately three times longer than Quick Process.
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseProcessModal">Cancel</button>
                    <button type="button" class="btn btn-warning" @onclick="ConfirmProcessWithAI">
                        <i class="bi bi-cpu me-1"></i>
                        @(_processingMode == ProcessingMode.EnhanceExisting
                            ? "Enhance"
                            : Post?.Status == SourcePostStatus.Processed ? "Re-process" : "Process")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showCleanupConfirm)
{
    <div class="modal fade show" style="display:block;" tabindex="-1" @onclick="CloseCleanupConfirm">
        <div class="modal-dialog modal-dialog-centered" style="max-width:420px;" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi bi-exclamation-triangle me-2" style="color:var(--accent-danger);"></i>
                        Clean Up Generated Assets
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseCleanupConfirm"></button>
                </div>
                <div class="modal-body">
                    <p>This will permanently delete all generated files for this post:</p>
                    <ul>
                        <li>TTS audio files (all parts + description)</li>
                        <li>Subtitle files</li>
                        <li>Video files</li>
                    </ul>
                    <p class="mb-0">The processed text content will not be affected.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseCleanupConfirm">Cancel</button>
                    <button type="button" class="btn btn-danger" @onclick="ConfirmCleanup">
                        <i class="bi bi-trash3 me-1"></i> Delete All Generated Assets
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (Post == null)
{
    <div class="container mt-4">
        <p><em>Loading...</em></p>
    </div>
}
else
{
    <div class="container mt-4 pb-5">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div style="flex:1;min-width:0;">
                <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                    <span style="@GetCommunityBadgeStyle(Post.Community);display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:12px;font-size:0.8rem;font-weight:700;">
                        <i class="bi bi-reddit"></i> r/@Post.Community
                    </span>
                    <span class="status-badge @GetStatusClass(Post.Status)">@Post.Status</span>
                </div>
                <h2 style="font-size:1.2rem;font-weight:600;line-height:1.3;margin-bottom:2px;">@Post.Title</h2>
                <small style="color:var(--text-muted);">
                    u/@Post.AuthorName • @Post.CreatedUtc.ToString("MMM d, yyyy")
                    • ↑ @Post.Score pts • @Post.WordCount words
                </small>
            </div>
            <div class="d-flex gap-2 flex-shrink-0 ms-3">
                <button class="btn btn-sm btn-outline-secondary" @onclick="GoBack">
                    <i class="bi bi-arrow-left"></i> Back
                </button>
                @if (!_isEditing)
                {
                    <button class="btn btn-sm btn-primary" @onclick="StartEditing">
                        <i class="bi bi-pencil"></i> Edit
                    </button>
                }
                else
                {
                    <button class="btn btn-sm btn-success" @onclick="UpdateProcessedPost">
                        <i class="bi bi-check2"></i> Save
                    </button>
                    <button class="btn btn-sm btn-secondary" @onclick="CancelEditing">Cancel</button>
                }
            </div>
        </div>

        <div class="row">
            <div class="col-md-4">
                <!-- Post actions row -->
                <div class="d-flex gap-2 flex-wrap mb-3">
                    <a href="@Post.ExternalUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-box-arrow-up-right"></i> View on @Post.Platform
                    </a>
                    @if (Post.ProcessedPost != null)
                    {
                        <button class="btn btn-sm @(Post.ProcessedPost.IsPosted ? "btn-success" : "btn-outline-success")"
                                @onclick="TogglePostedStatus" disabled="@_isEditing">
                            <i class="bi @(Post.ProcessedPost.IsPosted ? "bi-check2-circle" : "bi-circle")"></i>
                            @(Post.ProcessedPost.IsPosted ? "Posted" : "Mark as Posted")
                        </button>
                    }
                    <button class="btn btn-sm @(Post.Status == SourcePostStatus.Skipped ? "btn-warning" : "btn-outline-warning")"
                            @onclick="ToggleSkip" disabled="@_isEditing"
                            title="@(Post.Status == SourcePostStatus.Skipped ? "Restore post" : "Skip post")">
                        <i class="bi @(Post.Status == SourcePostStatus.Skipped ? "bi-arrow-counterclockwise" : "bi-x-circle")"></i>
                        @(Post.Status == SourcePostStatus.Skipped ? "Restore" : "Skip")
                    </button>
                </div>

                <!-- Raw text -->
                <div class="card mb-3">
                    <div class="card-header">Original Post</div>
                    <div class="card-body" style="white-space:pre-wrap;max-height:300px;overflow-y:auto;font-size:0.875rem;color:var(--text-secondary);">
                        @Post.RawText
                    </div>
                </div>

                <div class="d-grid gap-2 mb-4">
                    @if (!string.IsNullOrEmpty(_aiError))
                    {
                        <div class="alert alert-danger alert-dismissible py-2 mb-2">
                            <small>AI processing failed: @_aiError</small>
                            <button type="button" class="btn-close btn-close-sm" @onclick="() => _aiError = null" style="padding:8px;"></button>
                        </div>
                    }
                    <button type="button" class="btn btn-warning" @onclick="OpenProcessModal" disabled="@(_isProcessing || _isEditing)">
                        @if (_isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span> Processing...</span>
                        }
                        else
                        {
                            <span>@(Post.Status == SourcePostStatus.Processed ? "Re-process with AI" : "Process with AI")</span>
                        }
                    </button>

                    @if (_aiProgress != null)
                    {
                        <div class="mt-2">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <small class="fw-bold">@_aiProgress.Stage</small>
                                <small>@(_aiProgress.ProgressPercent)%</small>
                            </div>
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar progress-bar-striped progress-bar-animated bg-warning"
                                     role="progressbar"
                                     style="width: @(_aiProgress.ProgressPercent)%"
                                     aria-valuenow="@_aiProgress.ProgressPercent"
                                     aria-valuemin="0"
                                     aria-valuemax="100">
                                </div>
                            </div>
                        </div>
                    }

                    @if (Post.ProcessedPost != null && Post.Status == SourcePostStatus.Processed)
                    {
                        <div class="mt-3">
                            @if (_currentProgress != null)
                            {
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <small class="fw-bold">@_currentProgress.Stage</small>
                                        <small>@(_currentProgress.ProgressPercent)%</small>
                                    </div>
                                    <div class="progress" style="height: 20px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated @(_currentProgress.HasError ? "bg-danger" : "bg-primary")"
                                             role="progressbar"
                                             style="width: @(_currentProgress.ProgressPercent)%"
                                             aria-valuenow="@_currentProgress.ProgressPercent"
                                             aria-valuemin="0"
                                             aria-valuemax="100">
                                        </div>
                                    </div>
                                    <small class="text-muted">@_currentProgress.Message</small>
                                    @if (_currentProgress.HasError && !string.IsNullOrEmpty(_currentProgress.ErrorMessage))
                                    {
                                        <div class="mt-1">
                                            <small class="text-danger">@_currentProgress.ErrorMessage</small>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="d-flex gap-2 mb-2">
                                @if (Post.ProcessedPost.TtsStatus == TtsStatus.Generated)
                                {
                                    <span class="badge bg-success">TTS Generated</span>
                                }
                                @if (Post.ProcessedPost.VideoStatus == VideoStatus.Generated)
                                {
                                    <span class="badge bg-success">Video Generated</span>
                                }
                            </div>

                            <button type="button" class="btn btn-success w-100"
                                    @onclick="ShowGenerateDialog"
                                    disabled="@(_isProcessing || _isEditing || IsGenerating)">
                                <span>@(HasPreviousGeneration() ? "Re-generate" : "Generate")</span>
                            </button>

                            @if (IsGenerating)
                            {
                                <button type="button" class="btn btn-outline-danger w-100 mt-2"
                                        @onclick="CancelGeneration"
                                        disabled="@(_isProcessing || _isEditing || _isCanceling)">
                                    @if (_isCanceling)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        <span> Canceling...</span>
                                    }
                                    else
                                    {
                                        <span>Cancel Generation</span>
                                    }
                                </button>
                            }

                            @if (HasAnyGeneratedAssets())
                            {
                                <button type="button" class="btn btn-outline-danger w-100 mt-2"
                                        @onclick="ShowCleanupConfirm"
                                        disabled="@(_isProcessing || _isEditing || IsGenerating || _isCleaning)">
                                    @if (_isCleaning)
                                    {
                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                        <span> Cleaning up...</span>
                                    }
                                    else
                                    {
                                        <i class="bi bi-trash3"></i>
                                        <span> Clean Up Assets</span>
                                    }
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            <div class="col-md-8">
                @if (Post.ProcessedPost != null)
                {
                    <div class="card mb-4 border-primary shadow-sm">
                        <div class="card-header fw-bold" style="background:var(--accent-primary-dim);color:var(--accent-primary);border-color:var(--accent-primary);">
                            AI Processed Content
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Post Title (Social Media)</label>
                                @if (_isEditing)
                                {
                                    <input type="text" class="form-control" @bind="Post.ProcessedPost.Title" />
                                }
                                else
                                {
                                    <div class="content-display-field">@Post.ProcessedPost.Title</div>
                                }
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Post Description (Social Media)</label>
                                @if (_isEditing)
                                {
                                    <textarea class="form-control" rows="3" @bind="Post.ProcessedPost.Description"></textarea>
                                }
                                else
                                {
                                    <div class="content-display-field" style="white-space: pre-wrap;">@Post.ProcessedPost.Description</div>
                                    @if (!string.IsNullOrEmpty(Post.ProcessedPost.DescriptionAudioBlobPath?.SasUrl))
                                    {
                                        <div class="mt-2">
                                            <audio controls class="w-100">
                                                <source src="@Post.ProcessedPost.DescriptionAudioBlobPath.SasUrl" type="audio/mpeg">
                                                Your browser does not support the audio element.
                                            </audio>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Post Hashtags</label>
                                @if (_isEditing)
                                {
                                    <input type="text" class="form-control" @bind="_hashtagsText" placeholder="Enter hashtags separated by comma..." />
                                }
                                else
                                {
                                    <div class="content-display-field">@_hashtagsText</div>
                                }
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">Narrator Gender</label>
                                @if (_isEditing)
                                {
                                    <select class="form-select" @bind="Post.ProcessedPost.NarratorGender">
                                        @foreach (var gender in Enum.GetValues<NarratorGender>())
                                        {
                                            <option value="@gender">@gender</option>
                                        }
                                    </select>
                                }
                                else
                                {
                                    <div class="content-display-field">@Post.ProcessedPost.NarratorGender</div>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0">Content Parts</h4>
                        @if (_isEditing)
                        {
                            <button class="btn btn-outline-primary btn-sm" @onclick="AddPart">+ Add Part</button>
                        }
                    </div>

                    @foreach (var part in Post.ProcessedPost.Parts.OrderBy(p => p.Part))
                    {
                        <div class="card mb-3 border-secondary shadow-sm" @key="part">
                            <div class="card-header d-flex justify-content-between align-items-center py-2">
                                <div class="d-flex align-items-center">
                                    <span class="badge bg-secondary me-3">Part @part.Part</span>
                                    @if (_isEditing)
                                    {
                                        <div class="d-flex align-items-center">
                                            <small class="me-2 fw-bold">Order:</small>
                                            <input type="number" class="form-control form-control-sm" style="width: 70px;" @bind="part.Part" />
                                        </div>
                                    }
                                </div>
                                <div class="d-flex gap-1">
                                    @if (!_isEditing)
                                    {
                                        @if (!string.IsNullOrEmpty(part.VideoBlobPath?.SasUrl))
                                        {
                                            <button class="btn btn-sm btn-success"
                                                    @onclick="() => OpenVideoPreview(part.VideoBlobPath!.SasUrl)">
                                                <i class="bi bi-phone"></i> Preview Video
                                            </button>
                                            <a href="@part.VideoBlobPath!.SasUrl" download
                                               class="btn btn-sm btn-outline-success" target="_blank">
                                                <i class="bi bi-download"></i> Download
                                            </a>
                                        }

                                        <button class="btn btn-sm @(_copiedPartId == part.Id ? "btn-success" : "btn-outline-secondary")"
                                                @onclick="() => CopyPartToClipboard(part)">
                                            @if (_copiedPartId == part.Id)
                                            {
                                                <i class="bi bi-check2"></i> <span>Copied!</span>
                                            }
                                            else
                                            {
                                                <i class="bi bi-clipboard"></i> <span>Copy for Social</span>
                                            }
                                        </button>
                                    }
                                    @if (_isEditing)
                                    {
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => RemovePart(part)">
                                            Remove
                                        </button>
                                    }
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Processed Text</label>
                                    @if (_isEditing)
                                    {
                                        <textarea class="form-control" rows="4" @bind="part.ProcessedText"></textarea>
                                    }
                                    else
                                    {
                                        <div class="content-display-field" style="white-space: pre-wrap;">@part.ProcessedText</div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else if (Post.Status == SourcePostStatus.Raw)
                {
                    <div class="alert alert-info">
                        This post hasn't been processed by AI yet. Click "Process with AI" to generate social media content.
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private SourcePostDetailsDto? Post { get; set; }
    private string _hashtagsText = "";
    private Dictionary<ProcessedPostPartDto, string> _partHashtags = new();
    private bool _isProcessing = false;
    private bool _isEditing = false;
    private bool _isCanceling = false;
    private bool _isCleaning = false;
    private bool _showCleanupConfirm = false;
    private bool _showGenerateDialog = false;
    private bool _showProcessModal = false;
    private string? _previewVideoUrl;

    // AI settings
    private ProcessingMode _processingMode = ProcessingMode.Classic;
    private LlmProvider _llmProvider = LlmProvider.Gemini;
    private string _localModelName = "qwen2.5:7b";
    private bool _partsCountAuto = true;
    private int _partsCount = 3;
    private bool _wordsPerPartAuto = true;
    private int _wordsPerPart = 300;
    private HubConnection? _hubConnection;
    private GenerationProgressModel? _currentProgress;
    private Guid? _copiedPartId;
    private string? _aiError;
    private AiProcessingProgressModel? _aiProgress;

    private bool IsGenerating => Post?.ProcessedPost?.TtsStatus == TtsStatus.InProgress
                              || Post?.ProcessedPost?.VideoStatus == VideoStatus.InProgress;

    protected override async Task OnInitializedAsync()
    {
        await LoadPost();
        InitProgressFromStatus();

        _hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/video-generation"))
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<GenerationProgressModel>("ProgressUpdate", async (progress) =>
        {
            _currentProgress = progress;
            if (progress.IsComplete)
            {
                await LoadPost();
                _currentProgress = null;
            }
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<AiProcessingProgressModel>("AiProcessingUpdate", async (progress) =>
        {
            if (progress.IsComplete)
            {
                _isProcessing = false;
                _aiProgress = null;
                _aiError = progress.HasError ? progress.ErrorMessage : null;
                await LoadPost();
                if (Post?.ProcessedPost != null)
                    await _hubConnection!.InvokeAsync("JoinPostGroup", Post.ProcessedPost.Id);
            }
            else
            {
                _aiProgress = progress;
            }
            await InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();

        // Join source post group for AI processing updates
        await _hubConnection.InvokeAsync("JoinSourcePostGroup", Id);

        if (Post?.ProcessedPost != null)
        {
            await _hubConnection.InvokeAsync("JoinPostGroup", Post.ProcessedPost.Id);
        }
    }

    private void InitProgressFromStatus()
    {
        // Restore AI processing state on page load
        if (Post?.Status == SourcePostStatus.Processing)
        {
            _isProcessing = true;
            _aiProgress = new AiProcessingProgressModel
            {
                SourcePostId = Post.Id,
                Stage = "AI processing in progress…",
                ProgressPercent = 10
            };
        }

        if (Post?.ProcessedPost == null) return;
        var pp = Post.ProcessedPost;
        if (pp.TtsStatus == TtsStatus.InProgress)
        {
            _currentProgress = new GenerationProgressModel
            {
                ProcessedPostId = pp.Id,
                Stage = "TTS Generation",
                Message = "TTS generation is in progress…",
                ProgressPercent = 25
            };
        }
        else if (pp.VideoStatus == VideoStatus.InProgress)
        {
            _currentProgress = new GenerationProgressModel
            {
                ProcessedPostId = pp.Id,
                Stage = "Video Generation",
                Message = "Video generation is in progress…",
                ProgressPercent = 60
            };
        }
    }

    private async Task LoadPost()
    {
        Post = await Mediator.Send(new GetSourcePostDetailsQuery(Id));
        if (Post?.ProcessedPost != null)
        {
            _hashtagsText = string.Join(", ", Post.ProcessedPost.Hashtags);
            _partHashtags.Clear();
            foreach (var part in Post.ProcessedPost.Parts)
            {
                _partHashtags[part] = string.Join(", ", part.Hashtags);
            }
        }
    }

    private void OpenProcessModal()
    {
        _processingMode = Post?.ProcessedPost != null ? ProcessingMode.EnhanceExisting : ProcessingMode.Classic;
        _showProcessModal = true;
    }

    private void CloseProcessModal() => _showProcessModal = false;

    private async Task ConfirmProcessWithAI()
    {
        _showProcessModal = false;
        await ProcessWithAI();
    }

    private async Task ProcessWithAI()
    {
        if (Post == null) return;
        _isProcessing = true;
        _aiError = null;
        try
        {
            var partsCount = (_partsCountAuto || _processingMode == ProcessingMode.EnhanceExisting) ? (int?)null : _partsCount;
            var wordsPerPart = (_wordsPerPartAuto || _processingMode == ProcessingMode.EnhanceExisting) ? (int?)null : _wordsPerPart;
            var localModelName = _llmProvider == LlmProvider.Local && !string.IsNullOrWhiteSpace(_localModelName)
                ? _localModelName
                : null;
            await Mediator.Send(new QueueAiProcessingCommand(Post.Id, partsCount, wordsPerPart, _llmProvider, _processingMode, localModelName));
            Post.Status = SourcePostStatus.Processing;
            _isEditing = false;
        }
        catch
        {
            _isProcessing = false;
            throw;
        }
    }

    private async Task EnsureJoinedHubGroup()
    {
        if (_hubConnection?.State == HubConnectionState.Connected && Post?.ProcessedPost != null)
            await _hubConnection.InvokeAsync("JoinPostGroup", Post.ProcessedPost.Id);
    }

    private void StartEditing()
    {
        _isEditing = true;
    }

    private async Task CancelEditing()
    {
        await LoadPost();
        _isEditing = false;
    }

    private async Task UpdateProcessedPost()
    {
        if (Post?.ProcessedPost == null) return;

        var command = new UpdateProcessedPostCommand(
            Post.ProcessedPost.Id,
            Post.ProcessedPost.Title,
            Post.ProcessedPost.Description,
            _hashtagsText.Split(',', StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim()).ToList(),
            Post.ProcessedPost.NarratorGender,
            Post.ProcessedPost.Parts.Select(p => new UpdateProcessedPostPartDto(
                p.Id,
                p.ProcessedText,
                _partHashtags.GetValueOrDefault(p, "").Split(',', StringSplitOptions.RemoveEmptyEntries).Select(s => s.Trim()).ToList(),
                p.PublishedTo,
                p.Part
            )).ToList()
        );

        await Mediator.Send(command);
        await LoadPost();
        _isEditing = false;
    }

    private void AddPart()
    {
        if (Post?.ProcessedPost == null) return;

        var newPart = new ProcessedPostPartDto
        {
            Part = Post.ProcessedPost.Parts.Any() ? Post.ProcessedPost.Parts.Max(p => p.Part) + 1 : 1,
            ProcessedText = "",
            Hashtags = [],
            PublishedTo = []
        };

        Post.ProcessedPost.Parts.Add(newPart);
        _partHashtags[newPart] = "";
    }

    private void RemovePart(ProcessedPostPartDto part)
    {
        Post?.ProcessedPost?.Parts.Remove(part);
        _partHashtags.Remove(part);
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/source-posts");
    }

    private static string GetStatusClass(SourcePostStatus status) => status switch
    {
        SourcePostStatus.Raw        => "badge-raw",
        SourcePostStatus.Processed  => "badge-processed",
        SourcePostStatus.Approved   => "badge-approved",
        SourcePostStatus.Rejected   => "badge-rejected",
        SourcePostStatus.Skipped    => "badge-skipped",
        SourcePostStatus.Processing => "badge-processing",
        _ => "badge-inactive"
    };

    private static readonly string[] _communityColors =
    [
        "#5b6af0", "#e67e22", "#1abc9c", "#9b59b6",
        "#e74c3c", "#2ecc71", "#f39c12", "#3498db"
    ];

    private static string GetCommunityBadgeStyle(string community)
    {
        var hash = community.Aggregate(0, (acc, c) => acc * 31 + c);
        var color = _communityColors[Math.Abs(hash) % _communityColors.Length];
        return $"background:{color}25;color:{color};border:1px solid {color}60;";
    }

    private void ShowGenerateDialog()
    {
        _showGenerateDialog = true;
    }

    private void OpenVideoPreview(string url)
    {
        _previewVideoUrl = url;
    }

    private void CloseVideoPreview()
    {
        _previewVideoUrl = null;
    }

    private async Task CloseGenerateDialog()
    {
        _showGenerateDialog = false;
        await Task.CompletedTask;
    }

    private async Task OnGenerated()
    {
        await LoadPost();
        await EnsureJoinedHubGroup();
    }

    private bool HasPreviousGeneration()
    {
        return Post?.ProcessedPost?.TtsStatus == TtsStatus.Generated
            || Post?.ProcessedPost?.VideoStatus == VideoStatus.Generated;
    }

    private bool HasAnyGeneratedAssets() =>
        Post?.ProcessedPost?.TtsStatus is TtsStatus.Generated or TtsStatus.Failed
        || Post?.ProcessedPost?.VideoStatus is VideoStatus.Generated or VideoStatus.Failed;

    private void ShowCleanupConfirm() => _showCleanupConfirm = true;
    private void CloseCleanupConfirm() => _showCleanupConfirm = false;

    private async Task ConfirmCleanup()
    {
        if (Post?.ProcessedPost == null) return;
        _showCleanupConfirm = false;
        _isCleaning = true;
        try
        {
            await Mediator.Send(new CleanupPreviousAssetsCommand(Post.ProcessedPost.Id));
            await LoadPost();
        }
        finally
        {
            _isCleaning = false;
        }
    }

    private async Task CancelGeneration()
    {
        if (Post?.ProcessedPost == null) return;
        _isCanceling = true;
        try
        {
            await Mediator.Send(new CancelGenerationCommand(Post.ProcessedPost.Id));
            _currentProgress = null;
            await LoadPost();
        }
        finally
        {
            _isCanceling = false;
        }
    }

    private async Task CopyPartToClipboard(ProcessedPostPartDto part)
    {
        if (Post?.ProcessedPost == null) return;

        var hashtags = Post.ProcessedPost.Hashtags
            .Concat(part.Hashtags)
            .Select(t => t.Trim().StartsWith('#') ? t.Trim() : $"#{t.Trim()}")
            .Where(t => t.Length > 1)
            .Distinct();

        var hashtagsLine = string.Join(" ", hashtags);

        var prefix = Post.ProcessedPost.Parts.Count == 1 ? "[Full Story]" : $"[Part {part.Part}]";
        var text = $"{prefix} {Post.ProcessedPost.Title}";
        if (!string.IsNullOrWhiteSpace(hashtagsLine))
            text += $"\n\n{hashtagsLine}";

        await JS.InvokeVoidAsync("copyToClipboard", text);

        _copiedPartId = part.Id;
        StateHasChanged();
        await Task.Delay(2000);
        _copiedPartId = null;
        StateHasChanged();
    }

    private async Task TogglePostedStatus()
    {
        if (Post?.ProcessedPost == null) return;
        var newValue = !Post.ProcessedPost.IsPosted;
        await Mediator.Send(new MarkProcessedPostAsPostedCommand(Post.ProcessedPost.Id, newValue));
        Post.ProcessedPost.IsPosted = newValue;
        StateHasChanged();
    }

    private async Task ToggleSkip()
    {
        if (Post == null) return;
        await Mediator.Send(new ToggleSkipSourcePostCommand(Post.Id));
        Post.Status = Post.Status == SourcePostStatus.Skipped
            ? SourcePostStatus.Raw
            : SourcePostStatus.Skipped;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
