@page "/source-posts"
@using MediatR
@using TheContentor.Application.Features.SourcePosts.Models
@using TheContentor.Application.Features.SourcePosts.Queries
@using TheContentor.Domain.Enums
@inject IMediator Mediator
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Source Posts</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Source Posts</h1>
    <button class="btn btn-primary" @onclick="() => _showScrapDialog = true">Scrap Reddit</button>
</div>

<ScrapRedditDialog Show="_showScrapDialog" OnClose="() => _showScrapDialog = false" OnScrapped="RefreshList" />

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Search Title</label>
                <input type="text" class="form-control" @bind="_searchTitle" @bind:event="oninput" placeholder="Filter by title..." />
            </div>
            <div class="col-md-2">
                <label class="form-label">Platform</label>
                <select class="form-select" @bind="_filterPlatform">
                    <option value="">All</option>
                    @foreach (var platform in Enum.GetValues<SourcePlatform>())
                    {
                        <option value="@platform">@platform</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select class="form-select" @bind="_filterStatus">
                    <option value="">All</option>
                    @foreach (var status in Enum.GetValues<SourcePostStatus>())
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">TTS</label>
                <select class="form-select" @bind="_filterTtsStatus">
                    <option value="">All</option>
                    @foreach (var s in Enum.GetValues<TtsStatus>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Video</label>
                <select class="form-select" @bind="_filterVideoStatus">
                    <option value="">All</option>
                    @foreach (var s in Enum.GetValues<VideoStatus>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
        </div>
        <div class="row g-3 mt-1">
            <div class="col-md-2">
                <label class="form-label">Posted</label>
                <select class="form-select" @bind="_filterIsPostedStr">
                    <option value="">All</option>
                    <option value="true">Posted</option>
                    <option value="false">Not Posted</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Words min</label>
                <input type="number" class="form-control" @bind="_filterWordCountMin" placeholder="e.g. 300" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Words max</label>
                <input type="number" class="form-control" @bind="_filterWordCountMax" placeholder="e.g. 2000" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Ingested from</label>
                <input type="date" class="form-control" @bind="_filterDateFrom" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Ingested to</label>
                <input type="date" class="form-control" @bind="_filterDateTo" />
            </div>
        </div>
        <div class="row mt-2">
            <div class="col-auto">
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearFilters">Clear Filters</button>
            </div>
        </div>
    </div>
</div>

@if (_posts == null)
{
    <p><em>Loading...</em></p>
}
else if (!FilteredPosts.Any())
{
    <div class="alert alert-info">
        No source posts found matching filters.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th style="cursor: pointer" @onclick='() => SetSort("Platform")'>
                        Source @GetSortIcon("Platform")
                    </th>
                    <th style="cursor: pointer" @onclick='() => SetSort("Community")'>
                        Community @GetSortIcon("Community")
                    </th>
                    <th style="cursor: pointer" @onclick='() => SetSort("Title")'>
                        Title @GetSortIcon("Title")
                    </th>
                    <th style="cursor: pointer" @onclick='() => SetSort("WordCount")'>
                        Words @GetSortIcon("WordCount")
                    </th>
                    <th style="cursor: pointer" @onclick='() => SetSort("Score")'>
                        Score @GetSortIcon("Score")
                    </th>
                    <th style="cursor: pointer" @onclick='() => SetSort("UpvoteRatio")'>
                        Ratio @GetSortIcon("UpvoteRatio")
                    </th>
                    <th style="cursor: pointer" @onclick='() => SetSort("CreatedUtc")'>
                        Created @GetSortIcon("CreatedUtc")
                    </th>
                    <th style="cursor: pointer" @onclick='() => SetSort("IngestedUtc")'>
                        Ingested @GetSortIcon("IngestedUtc")
                    </th>
                    <th style="cursor: pointer" @onclick='() => SetSort("Status")'>
                        Status @GetSortIcon("Status")
                    </th>
                    <th style="cursor: pointer" @onclick='() => SetSort("TtsStatus")'>
                        TTS @GetSortIcon("TtsStatus")
                    </th>
                    <th style="cursor: pointer" @onclick='() => SetSort("VideoStatus")'>
                        Video @GetSortIcon("VideoStatus")
                    </th>
                    <th style="cursor: pointer" @onclick='() => SetSort("IsPosted")'>
                        Posted @GetSortIcon("IsPosted")
                    </th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var post in SortedPosts)
                {
                    <tr>
                        <td>
                            <span class="badge bg-secondary">@post.Platform</span>
                        </td>
                        <td>@post.Community</td>
                        <td>
                            @post.Title
                        </td>
                        <td>@post.WordCount</td>
                        <td>@post.Score</td>
                        <td>@(post.UpvoteRatio?.ToString("P0") ?? "N/A")</td>
                        <td>@post.CreatedUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@post.IngestedUtc.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <span class="badge @GetStatusClass(post.Status)">@post.Status</span>
                        </td>
                        <td>
                            @if (post.TtsStatus.HasValue)
                            {
                                <span class="badge @GetTtsStatusClass(post.TtsStatus.Value)">@post.TtsStatus</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (post.VideoStatus.HasValue)
                            {
                                <span class="badge @GetVideoStatusClass(post.VideoStatus.Value)">@post.VideoStatus</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            @if (post.IsPosted == true)
                            {
                                <span class="badge bg-success">Posted</span>
                            }
                            else if (post.IsPosted == false)
                            {
                                <span class="text-muted">—</span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-info" href="/source-posts/@post.Id">
                                View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private bool _showScrapDialog;
    private List<SourcePostListItemDto>? _posts;
    private string _searchTitle = "";
    private SourcePlatform? _filterPlatform;
    private SourcePostStatus? _filterStatus;
    private TtsStatus? _filterTtsStatus;
    private VideoStatus? _filterVideoStatus;
    private string _filterIsPostedStr = "";
    private int? _filterWordCountMin;
    private int? _filterWordCountMax;
    private DateTimeOffset? _filterDateFrom;
    private DateTimeOffset? _filterDateTo;
    private string _sortColumn = "IngestedUtc";
    private bool _sortAscending = false;

    protected override async Task OnInitializedAsync()
    {
        await RefreshList();
    }

    private async Task RefreshList()
    {
        _posts = await Mediator.Send(new GetSourcePostListQuery());
    }

    private bool? FilterIsPosted => _filterIsPostedStr switch
    {
        "true" => true,
        "false" => false,
        _ => null
    };

    private IEnumerable<SourcePostListItemDto> FilteredPosts
    {
        get
        {
            if (_posts == null) return [];

            return _posts.Where(p =>
                (string.IsNullOrWhiteSpace(_searchTitle) || p.Title.Contains(_searchTitle, StringComparison.OrdinalIgnoreCase)) &&
                (_filterPlatform == null || p.Platform == _filterPlatform) &&
                (_filterStatus == null || p.Status == _filterStatus) &&
                (_filterTtsStatus == null || p.TtsStatus == _filterTtsStatus) &&
                (_filterVideoStatus == null || p.VideoStatus == _filterVideoStatus) &&
                (FilterIsPosted == null || p.IsPosted == FilterIsPosted) &&
                (_filterWordCountMin == null || p.WordCount >= _filterWordCountMin) &&
                (_filterWordCountMax == null || p.WordCount <= _filterWordCountMax) &&
                (_filterDateFrom == null || p.IngestedUtc >= _filterDateFrom) &&
                (_filterDateTo == null || p.IngestedUtc <= _filterDateTo.Value.AddDays(1))
            );
        }
    }

    private void ClearFilters()
    {
        _searchTitle = "";
        _filterPlatform = null;
        _filterStatus = null;
        _filterTtsStatus = null;
        _filterVideoStatus = null;
        _filterIsPostedStr = "";
        _filterWordCountMin = null;
        _filterWordCountMax = null;
        _filterDateFrom = null;
        _filterDateTo = null;
    }

    private IEnumerable<SourcePostListItemDto> SortedPosts
    {
        get
        {
            var filtered = FilteredPosts;
            return _sortColumn switch
            {
                "Platform" => _sortAscending ? filtered.OrderBy(p => p.Platform) : filtered.OrderByDescending(p => p.Platform),
                "Community" => _sortAscending ? filtered.OrderBy(p => p.Community) : filtered.OrderByDescending(p => p.Community),
                "Title" => _sortAscending ? filtered.OrderBy(p => p.Title) : filtered.OrderByDescending(p => p.Title),
                "WordCount" => _sortAscending ? filtered.OrderBy(p => p.WordCount) : filtered.OrderByDescending(p => p.WordCount),
                "Score" => _sortAscending ? filtered.OrderBy(p => p.Score) : filtered.OrderByDescending(p => p.Score),
                "UpvoteRatio" => _sortAscending ? filtered.OrderBy(p => p.UpvoteRatio) : filtered.OrderByDescending(p => p.UpvoteRatio),
                "CreatedUtc" => _sortAscending ? filtered.OrderBy(p => p.CreatedUtc) : filtered.OrderByDescending(p => p.CreatedUtc),
                "IngestedUtc" => _sortAscending ? filtered.OrderBy(p => p.IngestedUtc) : filtered.OrderByDescending(p => p.IngestedUtc),
                "Status" => _sortAscending ? filtered.OrderBy(p => p.Status) : filtered.OrderByDescending(p => p.Status),
                "TtsStatus" => _sortAscending ? filtered.OrderBy(p => p.TtsStatus) : filtered.OrderByDescending(p => p.TtsStatus),
                "VideoStatus" => _sortAscending ? filtered.OrderBy(p => p.VideoStatus) : filtered.OrderByDescending(p => p.VideoStatus),
                "IsPosted" => _sortAscending ? filtered.OrderBy(p => p.IsPosted) : filtered.OrderByDescending(p => p.IsPosted),
                _ => filtered
            };
        }
    }

    private void SetSort(string column)
    {
        if (_sortColumn == column)
        {
            _sortAscending = !_sortAscending;
        }
        else
        {
            _sortColumn = column;
            _sortAscending = true;
        }
    }

    private string GetSortIcon(string column)
    {
        if (_sortColumn != column) return "";
        return _sortAscending ? "↑" : "↓";
    }

    private string GetStatusClass(SourcePostStatus status) => status switch
    {
        SourcePostStatus.Raw => "bg-info",
        SourcePostStatus.Processed => "bg-primary",
        SourcePostStatus.Approved => "bg-success",
        SourcePostStatus.Rejected => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetTtsStatusClass(TtsStatus status) => status switch
    {
        TtsStatus.Generated => "bg-success",
        TtsStatus.InProgress => "bg-warning text-dark",
        TtsStatus.Failed => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetVideoStatusClass(VideoStatus status) => status switch
    {
        VideoStatus.Generated => "bg-success",
        VideoStatus.InProgress => "bg-warning text-dark",
        VideoStatus.Failed => "bg-danger",
        _ => "bg-secondary"
    };
}
